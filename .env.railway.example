# Copy these into Railway → your service → Variables
# Do NOT commit real secrets to git.

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=change-me-generate-a-long-random-string

# DATABASE_URL — REQUIRED. Do NOT paste this file's comments into Railway.
#
# In Railway dashboard (web service → Variables):
#   1. Click "+ New Variable" → "Add Reference"
#   2. Select your MySQL service
#   3. Pick variable: MYSQL_URL
#   4. Name it: DATABASE_URL
#
# The value must look like:
#   mysql://root:xxxxx@mysql.railway.internal:3306/railway
# NOT placeholder text from docs.

JWT_PASSPHRASE=change-me-long-random-passphrase-for-production
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem

# Mobile app + web (adjust after deploy)
CORS_ALLOW_ORIGIN=^https?://.*

MAILER_DSN=smtp://user:pass@smtp.example.com:587
MAILER_FROM_ADDRESS=noreply@yourdomain.com
MAILER_FROM_NAME=Cloudrobe
MAILER_DEFAULT_FROM="Cloudrobe <noreply@yourdomain.com>"
CONTACT_INBOX=noreply@yourdomain.com
CONTACT_NOTIFY_EMAIL=noreply@yourdomain.com
CONTACT_TO_EMAIL=noreply@yourdomain.com
CONTACT_FROM_EMAIL=noreply@yourdomain.com

OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
