{% extends 'base.html.twig' %}

{% block title %}Products | Cosplay Store{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --primary: #e5a3a3;
            --secondary: #df9152;
            --accent: #ecc9c9;
            --dark: #5c3a3a;
            --light: #fdf6f6;
        }

        body { background: var(--light); font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }

        .hero-section {
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            color: white;
            padding: 4rem 2rem;
            text-align: center;
            border-radius: 0 0 50px 50px;
            box-shadow: 0 10px 30px rgba(229, 163, 163, 0.4);
        }

        .hero-section h1 { font-size: 3rem; font-weight: 800; margin: 0; text-shadow: 2px 2px 6px rgba(0,0,0,0.2); }
        .hero-section p { font-size: 1.2rem; margin-top: 0.5rem; opacity: 0.9; }

        .action-bar { display: flex; justify-content: flex-end; margin: 2rem 0; }

        .btn-new {
            background: linear-gradient(135deg, var(--secondary), #c97642);
            color: white; padding: 0.8rem 2rem; border-radius: 50px;
            text-decoration: none; font-weight: 600; display: inline-flex; align-items: center; gap: 0.5rem;
            transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(223, 145, 82, 0.4); font-size: 1rem;
        }

        .btn-new:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(223, 145, 82, 0.6); }
        .btn-new::before { content: "✨"; }

        .products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2rem; }

        .product-card {
            background: white; border-radius: 20px; overflow: hidden;
            box-shadow: 0 6px 20px rgba(0,0,0,0.08); transition: all 0.3s ease; border: 2px solid transparent;
        }

        .product-card:hover {
            transform: translateY(-5px); box-shadow: 0 12px 35px rgba(229, 163, 163, 0.4); border-color: var(--primary);
        }

        .product-image { width: 100%; height: 220px; object-fit: cover; background: linear-gradient(135deg, var(--accent), #f5e5e5);
            display: flex; align-items: center; justify-content: center; font-size: 4rem; color: var(--primary); transition: transform 0.3s ease;
        }

        .product-card:hover .product-image { transform: scale(1.05); }

        .product-content { padding: 1.5rem; }
        .product-name { font-size: 1.3rem; font-weight: 700; color: var(--dark); margin-bottom: 0.5rem; }
        .product-description { color: #666; font-size: 0.95rem; margin-bottom: 1rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
        .product-price { font-size: 1.4rem; font-weight: 700; color: var(--secondary); margin-bottom: 1rem; }

        .product-actions { display: flex; gap: 0.5rem; }
        .btn-action { flex: 1; padding: 0.5rem 1rem; border-radius: 12px; text-decoration: none; text-align: center; font-weight: 600; transition: all 0.3s ease; font-size: 0.9rem; }
        .btn-show { background: var(--primary); color: white; }
        .btn-show:hover { background: #d88f8f; }
        .btn-edit { background: var(--secondary); color: white; }
        .btn-edit:hover { background: #c97642; }
        .btn-delete { background: #e74c3c; color: white; }
        .btn-delete:hover { background: #c0392b; }

        .empty-state { text-align: center; padding: 5rem 2rem; background: var(--light); border-radius: 20px; margin: 2rem 0; border: 2px dashed var(--accent); transition: transform 0.3s ease; }
        .empty-state:hover { transform: translateY(-3px); }
        .empty-state-icon { font-size: 6rem; margin-bottom: 1rem; }
        .empty-state h3 { color: var(--dark); font-size: 1.7rem; margin-bottom: 0.5rem; }
        .empty-state p { color: #666; margin-bottom: 2rem; font-size: 1rem; }
    </style>
{% endblock %}

{% block body %}
<div class="hero-section">
    <div class="container">
        <h1>Cloudrobe Products</h1>
        <p>cosplay collection</p>
    </div>
</div>

{# add products #}
<div class="container">
    <div class="action-bar">
        <a href="{{ path('app_products_new') }}" class="btn-new">Add New Product</a>
    </div>

    {% if products is not empty %}
        <div class="products-grid">
            {% for product in products %}
                <div class="product-card">
                    <div class="product-image">
                        {% if product.image %}
                            <img src="{{ product.image }}" alt="{{ product.name }}">
                        {% else %}
                            🎭
                        {% endif %}
                    </div>
                    <div class="product-content">
                        <div class="product-name">{{ product.name }}</div>
                        <div class="product-description">{{ product.description }}</div>
                        <div class="product-price">${{ product.price|number_format(2) }}</div>
                        <div class="product-actions">
                            <a href="{{ path('app_products_show', {'id': product.id}) }}" class="btn-action btn-show">View</a>
                            <a href="{{ path('app_products_edit', {'id': product.id}) }}" class="btn-action btn-edit">Edit</a>

                            {# Delete #}
                            <form method="post" action="{{ path('app_products_delete', {'id': product.id}) }}" onsubmit="return confirm('Are you sure you want to delete this product?');" style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                                <button type="submit" class="btn-action btn-delete">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="empty-state">
            <div class="empty-state-icon">🎪</div>
            <h3>No Products Yet!</h3>
            <p>zebzebzebzeb.</p>
        </div>
    {% endif %}
</div>
{% endblock %}
