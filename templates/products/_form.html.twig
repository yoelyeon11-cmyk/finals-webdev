{% extends 'admin/base.html.twig' %}

{% block title %}{{ product.id ? 'Edit' : 'New' }} Product | Cosplay Store{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Keep your existing CSS, unchanged */
    </style>
{% endblock %}

{% block body %}
    <div class="hero-section">
        <div class="container">
            <h1>
                {% if product.id %}
                    Edit Product
                {% else %}
                    ➕ Create New Product
                {% endif %}
            </h1>
        </div>
    </div>

    <div class="container">
        <div class="form-container">
            {{ form_start(form) }}

            <div class="form-group">
                {{ form_label(form.name, 'Product Name', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'e.g., Naruto Uzumaki Costume'}}) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="form-group">
                {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'placeholder': 'Describe the product'}}) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="form-group">
                {{ form_label(form.price, 'Price', {'label_attr': {'class': 'form-label'}}) }}
                <div class="price-input-wrapper">
                    {{ form_widget(form.price, {'attr': {'class': 'form-control', 'step': '0.01'}}) }}
                </div>
                {{ form_errors(form.price) }}
            </div>

            <div class="form-group">
                {{ form_label(form.category, 'Category', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.category, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.category) }}
            </div>

            <div class="form-group">
                {{ form_label(form.imageFile, 'Upload Product Image', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.imageFile) }}

                <div class="image-preview-container">
                    {% if product.image %}
                        <img src="{{ product_image_url(product.image) }}" class="image-preview">
                    {% else %}
                        <div class="image-placeholder">🎭</div>
                    {% endif %}
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    {% if product.id %}Update Product{% else %}Create Product{% endif %}
                </button>
                <a href="{{ path('admin_product_index') }}" class="btn btn-secondary">Cancel</a>
            </div>

            {{ form_end(form) }}

            {% if product.id %}
                <div class="delete-section">
                    <h3>Danger Zone</h3>
                    <form method="post" action="{{ path('admin_product_delete', {'id': product.id}) }}" onsubmit="return confirm('Are you sure you want to delete this product? This action cannot be undone.');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                        <button type="submit" class="btn btn-danger">Delete Product</button>
                    </form>
                </div>
            {% endif %}
        </div>
    </div>

    <script>
        // Optional: live image preview from URL
        const imageInput = document.getElementById('imageInput');
        const imagePreviewContainer = document.querySelector('.image-preview-container');

        if (imageInput) {
            imageInput.addEventListener('input', function() {
                const url = this.value.trim();
                imagePreviewContainer.innerHTML = url ? `<img src="${url}" class="image-preview">` : '<div class="image-placeholder">🎭</div>';
            });
        }
    </script>
{% endblock %}
