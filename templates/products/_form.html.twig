{% extends 'base.html.twig' %}

{% block title %}{{ product.id ? 'Edit' : 'New' }} Product | Cosplay Store{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --primary: #9333ea;
            --secondary: #ec4899;
            --accent: #f59e0b;
            --dark: #1e1b4b;
            --light: #faf5ff;
        }

        .hero-section {
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            color: white;
            padding: 2.5rem 0;
            margin-bottom: 2rem;
            border-radius: 0 0 50px 50px;
            box-shadow: 0 10px 30px rgba(147, 51, 234, 0.3);
        }

        .hero-section h1 {
            font-size: 2rem;
            font-weight: 700;
            margin: 0;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .form-container {
            max-width: 800px;
            margin: 0 auto;
            background: white;
            padding: 3rem;
            border-radius: 30px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
            border: 2px solid var(--light);
        }

        .form-group {
            margin-bottom: 2rem;
        }

        .form-label {
            display: block;
            font-weight: 600;
            color: var(--dark);
            margin-bottom: 0.5rem;
            font-size: 1rem;
        }

        .form-label::before {
            content: "✨ ";
        }

        .form-control {
            width: 100%;
            padding: 0.875rem 1.25rem;
            border: 2px solid #e9d5ff;
            border-radius: 15px;
            font-size: 1rem;
            transition: all 0.3s ease;
            font-family: inherit;
        }

        .form-control:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(147, 51, 234, 0.1);
        }

        textarea.form-control {
            min-height: 120px;
            resize: vertical;
        }

        .form-hint {
            font-size: 0.875rem;
            color: #666;
            margin-top: 0.375rem;
            font-style: italic;
        }

        .form-actions {
            display: flex;
            gap: 1rem;
            margin-top: 3rem;
            padding-top: 2rem;
            border-top: 2px solid var(--light);
        }

        .btn {
            padding: 1rem 2.5rem;
            border: none;
            border-radius: 50px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            justify-content: center;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            flex: 1;
            box-shadow: 0 4px 15px rgba(147, 51, 234, 0.4);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(147, 51, 234, 0.6);
        }

        .btn-primary::before {
            content: "💾";
        }

        .btn-secondary {
            background: #f3f4f6;
            color: var(--dark);
        }

        .btn-secondary:hover {
            background: #e5e7eb;
        }

        .btn-secondary::before {
            content: "↩️";
        }

        .btn-danger {
            background: #ef4444;
            color: white;
            padding: 0.75rem 1.5rem;
        }

        .btn-danger:hover {
            background: #dc2626;
        }

        .btn-danger::before {
            content: "🗑️";
        }

        .image-preview-container {
            margin-top: 1rem;
            position: relative;
        }

        .image-preview {
            width: 100%;
            max-width: 300px;
            height: 300px;
            border-radius: 15px;
            object-fit: cover;
            border: 2px solid var(--light);
        }

        .image-placeholder {
            width: 100%;
            max-width: 300px;
            height: 300px;
            border-radius: 15px;
            background: linear-gradient(135deg, var(--light), #e9d5ff);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 4rem;
            border: 2px dashed var(--primary);
        }

        .price-input-wrapper {
            position: relative;
        }

        .price-input-wrapper::before {
            content: "$";
            position: absolute;
            left: 1.25rem;
            top: 50%;
            transform: translateY(-50%);
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--primary);
        }

        .price-input-wrapper .form-control {
            padding-left: 2.5rem;
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--primary);
        }

        .delete-section {
            margin-top: 3rem;
            padding-top: 2rem;
            border-top: 2px solid #fee2e2;
            text-align: center;
        }

        .delete-section h3 {
            color: #991b1b;
            font-size: 1rem;
            margin-bottom: 1rem;
        }

        @media (max-width: 768px) {
            .form-container {
                padding: 2rem 1.5rem;
            }

            .form-actions {
                flex-direction: column;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="hero-section">
        <div class="container">
            <h1>
                {% if product.id %}
                    ✏️ Edit Product
                {% else %}
                    ➕ Create New Product
                {% endif %}
            </h1>
        </div>
    </div>

    <div class="container">
        <div class="form-container">
            {{ form_start(form) }}

                <div class="form-group">
                    {{ form_label(form.name, 'Product Name', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'e.g., Naruto Uzumaki Costume'}}) }}
                    {{ form_errors(form.name) }}
                    <div class="form-hint">Give your product a catchy, descriptive name</div>
                </div>

                <div class="form-group">
                    {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.description, {'attr': {'class': 'form-control', 'placeholder': 'Describe the product, materials, sizes available, etc.'}}) }}
                    {{ form_errors(form.description) }}
                    <div class="form-hint">Provide detailed information to help customers make a decision</div>
                </div>

                <div class="form-group">
                    {{ form_label(form.price, 'Price', {'label_attr': {'class': 'form-label'}}) }}
                    <div class="price-input-wrapper">
                        {{ form_widget(form.price, {'attr': {'class': 'form-control', 'placeholder': '0.00', 'step': '0.01'}}) }}
                    </div>
                    {{ form_errors(form.price) }}
                    <div class="form-hint">Set a competitive price in USD</div>
                </div>

                <div class="form-group">
                    {{ form_label(form.image, 'Product Image URL', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.image, {'attr': {'class': 'form-control', 'placeholder': 'https://example.com/image.jpg', 'id': 'imageInput'}}) }}
                    {{ form_errors(form.image) }}
                    <div class="form-hint">Enter the URL of your product image</div>
                    
                    <div class="image-preview-container" id="imagePreviewContainer">
                        {% if product.image %}
                            <img src="{{ product.image }}" alt="Preview" class="image-preview" id="imagePreview">
                        {% else %}
                            <div class="image-placeholder" id="imagePlaceholder">🎭</div>
                        {% endif %}
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">
                        {% if product.id %}Update Product{% else %}Create Product{% endif %}
                    </button>
                    <a href="{{ path('app_products_index') }}" class="btn btn-secondary">Cancel</a>
                </div>

            {{ form_end(form) }}

            {% if product.id %}
                <div class="delete-section">
                    <h3>⚠️ Danger Zone</h3>
                    {{ form_start(delete_form) }}
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this product? This action cannot be undone.');">
                            Delete Product
                        </button>
                    {{ form_end(delete_form) }}
                </div>
            {% endif %}
        </div>
    </div>

    <script>
        // Image preview functionality
        const imageInput = document.getElementById('imageInput');
        const imagePreview = document.getElementById('imagePreview');
        const imagePlaceholder = document.getElementById('imagePlaceholder');
        const imagePreviewContainer = document.getElementById('imagePreviewContainer');

        if (imageInput) {
            imageInput.addEventListener('input', function() {
                const url = this.value.trim();
                
                if (url) {
                    if (!imagePreview) {
                        const img = document.createElement('img');
                        img.id = 'imagePreview';
                        img.className = 'image-preview';
                        imagePreviewContainer.innerHTML = '';
                        imagePreviewContainer.appendChild(img);
                    }
                    
                    const preview = document.getElementById('imagePreview');
                    preview.src = url;
                    preview.onerror = function() {
                        imagePreviewContainer.innerHTML = '<div class="image-placeholder">❌</div>';
                    };
                } else {
                    imagePreviewContainer.innerHTML = '<div class="image-placeholder" id="imagePlaceholder">🎭</div>';
                }
            });
        }
    </script>
{% endblock %}