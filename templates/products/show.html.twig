{% extends 'admin/base.html.twig' %}

{% block title %}{{ product.name }} | Product Details{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --primary: #e5a3a3;
            --secondary: #df9152;
            --dark: #5c3a3a;
            --light: #fdf6f6;
        }

        body { background: var(--light); font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 2rem 0 1rem 0;
        }

        .header h2 { font-size: 2rem; color: var(--dark); margin: 0; }
        .btn-back {
            background: var(--secondary); color: white; padding: 0.5rem 1rem;
            border-radius: 50px; text-decoration: none; font-weight: 600;
        }

        .product-details { display: flex; flex-wrap: wrap; gap: 2rem; margin-top: 1rem; }
        .product-image { max-width: 320px; border-radius: 15px; overflow: hidden; }
        .product-image img { width: 100%; object-fit: cover; }

        .product-info { flex: 1; min-width: 250px; background: white; padding: 2rem; border-radius: 20px; box-shadow: 0 6px 20px rgba(0,0,0,0.08); }
        .product-info ul { list-style: none; padding: 0; }
        .product-info li { margin-bottom: 1rem; font-size: 1rem; color: var(--dark); }
        .product-info li strong { color: var(--secondary); }

        .action-buttons { margin-top: 2rem; display: flex; gap: 1rem; }
        .btn-edit { background: var(--primary); color: white; padding: 0.5rem 1.25rem; border-radius: 50px; text-decoration: none; font-weight: 600; }
        .btn-edit:hover { opacity: 0.9; }
        .btn-delete { background: #ef4444; color: white; padding: 0.5rem 1.25rem; border-radius: 50px; border: none; cursor: pointer; font-weight: 600; }
        .btn-delete:hover { opacity: 0.9; }
    </style>
{% endblock %}

{% block body %}
    <div class="header">
        <h2>{{ product.name }}</h2>
        <a class="btn-back" href="{{ path('admin_product_index') }}">Back to Products</a>
    </div>

    <div class="product-details">
        {% if product.image %}
            <div class="product-image">
                <img src="{{ product.image }}" alt="{{ product.name }}">
            </div>
        {% endif %}

        <div class="product-info">
            <ul>
                <li><strong>Price:</strong> ${{ product.price|number_format(2) }}</li>
                <li><strong>Stock:</strong> {{ product.stock ?? 0 }}</li>
                <li><strong>Category:</strong> {{ product.category ? product.category.name : '—' }}</li>
                <li><strong>Description:</strong> {{ product.description }}</li>
            </ul>

            <div class="action-buttons">
                <a href="{{ path('admin_product_edit', {'id': product.id}) }}" class="btn-edit">Edit Product</a>

                {# Delete Form #}
                <form method="post" action="{{ path('admin_product_delete', {'id': product.id}) }}" onsubmit="return confirm('Are you sure you want to delete this product?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                    <button type="submit" class="btn-delete">Delete Product</button>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
