{% extends 'admin/base.html.twig' %}

{% block title %}Search Results{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        body {
            background-color: #fdf6f6;
        }

        .search-results-section {
            padding: 60px 0;
            min-height: 100vh;
        }

        .results-title {
            text-align: center;
            font-size: 2.2rem;
            color: #5c3a3a;
            margin-bottom: 40px;
            font-weight: 600;
        }

        .no-results {
            text-align: center;
            font-size: 1.2rem;
            color: #999;
        }

        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 30px;
            max-width: 1000px;
            margin: 0 auto;
            justify-items: center;
        }

        .product-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            overflow: hidden;
            text-align: center;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            width: 240px;
        }

        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 6px 18px rgba(0,0,0,0.15);
        }

        .product-image img {
            width: 100%;
            height: 240px;
            object-fit: cover;
        }

        .product-info {
            padding: 16px;
        }

        .product-info h3 {
            font-size: 1.2rem;
            color: #5c3a3a;
            margin-bottom: 8px;
        }

        .price {
            font-size: 1rem;
            color: #df9152;
            font-weight: bold;
            margin-bottom: 12px;
        }

        .view-btn {
            display: inline-block;
            background-color: #e5a3a3;
            color: #fff;
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 8px;
            transition: background-color 0.3s ease;
        }

        .view-btn:hover {
            background-color: #df9152;
        }
    </style>
{% endblock %}

{% block body %}
    <section class="search-results-section">
        <div class="container">
            <h2 class="results-title">Results for "{{ query }}"</h2>

            {% if products is empty %}
                <p class="no-results">No products found matching your search.</p>
            {% else %}
                <div class="product-grid">
                    {% for product in products %}
                        <div class="product-card">
                            <div class="product-image">
                                <img src="/uploads/{{ product.image }}" alt="{{ product.name }}">
                            </div>
                            <div class="product-info">
                                <h3>{{ product.name }}</h3>
                                <p class="price">${{ product.price }}</p>
                                <a href="{{ path('admin_product_show', { id: product.id }) }}" class="view-btn">
                                    View Details
                                </a>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </section>
{% endblock %}
