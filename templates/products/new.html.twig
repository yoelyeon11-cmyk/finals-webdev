{% extends 'admin/base.html.twig' %}

{% block title %}Add New Product | Cosplay Store{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --primary: #e5a3a3;
            --secondary: #df9152;
            --accent: #ecc9c9;
            --dark: #5c3a3a;
            --light: #fdf6f6;
        }

        body { 
            background: var(--light); 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
        }

        .hero-section {
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            color: white;
            padding: .9rem 1rem;
            text-align: center;
            border-radius: 0 0 0px 0px;
            box-shadow: 0 10px 30px rgba(229, 163, 163, 0.4);
            margin: -30px -30px 2rem -30px;
            width: calc(100% + 60px);
        }

        .hero-section h1 { font-size: 2.8rem; font-weight: 800; margin: 0; text-shadow: 2px 2px 6px rgba(0,0,0,0.2); }
        .hero-section p { font-size: 1.2rem; margin-top: 0.5rem; opacity: 0.9; }

        .form-container {
            max-width: 700px;
            margin: 0 auto 3rem auto;
            background: white;
            padding: 2.5rem 3rem;
            border-radius: 20px;
            box-shadow: 0 6px 20px rgba(0,0,0,0.08);
        }

        .form-group { margin-bottom: 1.5rem; }
        .form-label { display: block; font-weight: 600; margin-bottom: 0.5rem; color: var(--dark); }
        .form-control { width: 100%; padding: 0.8rem 1rem; border-radius: 12px; border: 2px solid var(--accent); font-size: 1rem; transition: all 0.3s ease; }
        .form-control:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(229,163,163,0.2); }
        textarea.form-control { resize: vertical; min-height: 100px; }

        .form-actions { display: flex; gap: 1rem; margin-top: 2rem; }
        .btn-submit { background: linear-gradient(135deg, var(--secondary), #c97642); color: white; padding: 0.8rem 2rem; border-radius: 50px; font-weight: 600; border: none; cursor: pointer; }
        .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(223,145,82,0.4); }
        .btn-cancel { background: var(--accent); color: var(--dark); padding: 0.8rem 2rem; border-radius: 50px; font-weight: 600; text-decoration: none; text-align: center; }

        .image-preview-container { margin-top: 1rem; position: relative; }
        .image-preview { width: 100%; max-width: 300px; height: 300px; border-radius: 15px; object-fit: cover; border: 2px solid var(--light); }
        .image-placeholder { width: 100%; max-width: 300px; height: 300px; border-radius: 15px; background: linear-gradient(135deg, var(--light), #e9d5ff); display: flex; align-items: center; justify-content: center; font-size: 4rem; border: 2px dashed var(--primary); }

        .form-errors { background: #fee2e2; color: #991b1b; padding: 0.75rem; border-radius: 8px; margin-bottom: 1rem; }
    </style>
{% endblock %}

{% block body %}
    <div class="hero-section">
        <h1>Add New Product</h1>
        <p>Fill in the details for your new cosplay product</p>
    </div>

    <div class="form-container">
        {% if not form.vars.valid %}
            <div class="form-errors">{{ form_errors(form) }}</div>
        {% endif %}

        {{ form_start(form, { 'attr': { 'enctype': 'multipart/form-data' } }) }}

            <div class="form-group">
                {{ form_label(form.name) }}
                {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': ''}}) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="form-group">
                {{ form_label(form.description) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'placeholder': ''}}) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="form-group">
                {{ form_label(form.price) }}
                {{ form_widget(form.price, {'attr': {'class': 'form-control', 'placeholder': '', 'step':'0.01'}}) }}
                {{ form_errors(form.price) }}
            </div>

            <div class="form-group">
                {{ form_label(form.category) }}
                {{ form_widget(form.category, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.category) }}
            </div>

            <div class="form-group">
                {{ form_label(form.imageFile, 'Product Image') }}
                {{ form_widget(form.imageFile) }}
                {{ form_errors(form.imageFile) }}

                <div class="image-preview-container">
                    <div class="image-placeholder" id="imagePlaceholder">:3</div>
                </div>
            </div>

            <div class="form-actions">
                <a href="{{ path('admin_product_index') }}" class="btn-cancel">Cancel</a>
                <button type="submit" class="btn-submit">Save Product</button>
            </div>

        {{ form_end(form) }}
    </div>

    <script>
        // Live image preview
        const imageInput = document.getElementById('{{ form.imageFile.vars.id }}');
        const imagePlaceholder = document.getElementById('imagePlaceholder');

        if (imageInput) {
            imageInput.addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (!file) return;

                const reader = new FileReader();
                reader.onload = function(e) {
                    imagePlaceholder.outerHTML = '<img src="' + e.target.result + '" class="image-preview">';
                }
                reader.readAsDataURL(file);
            });
        }
    </script>
{% endblock %}
