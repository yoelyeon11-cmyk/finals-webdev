{% extends 'admin/base.html.twig' %}

{% block title %}Edit Profile | Cloudrobe Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --primary: #ecc9c9;
            --secondary: #df9152;
            --accent: #e5a3a3;
            --dark: #5c3a3a;
            --light: #fdf6f6;
        }

        .hero-section {
            background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
            color: white;
            padding: 2rem;
            text-align: center;
            box-shadow: 0 10px 30px rgba(229, 163, 163, 0.4);
            margin: -30px -30px 2rem -30px;
            width: calc(100% + 60px);
        }

        .hero-section h1 {
            font-size: 2.2rem;
            font-weight: 800;
            margin: 0;
            color: var(--dark);
        }

        .form-container {
            max-width: 600px;
            margin: 0 auto;
            background: white;
            padding: 2.5rem;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(92, 58, 58, 0.12);
        }

        .form-group {
            margin-bottom: 1.75rem;
        }

        label {
            display: block;
            font-weight: 600;
            margin-bottom: 0.625rem;
            color: var(--dark);
            font-size: 0.95rem;
        }

        input[type="text"],
        input[type="email"],
        textarea,
        input[type="file"] {
            width: 100%;
            padding: 0.875rem 1rem;
            border: 2px solid var(--accent);
            border-radius: 10px;
            font-size: 1rem;
            color: var(--dark);
            background-color: var(--light);
            transition: all 0.3s ease;
            box-sizing: border-box;
        }

        textarea {
            resize: vertical;
            font-family: inherit;
        }

        input[type="text"]:focus,
        input[type="email"]:focus,
        textarea:focus {
            outline: none;
            border-color: var(--secondary);
            background-color: white;
            box-shadow: 0 0 0 3px rgba(223, 145, 82, 0.15);
        }

        .current-picture {
            margin-top: 0.5rem;
            text-align: center;
        }

        .current-picture img {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid var(--accent);
        }

        .form-errors {
            color: #c53030;
            font-size: 0.875rem;
            margin-top: 0.5rem;
            padding: 0.5rem;
            background-color: #fee;
            border-radius: 6px;
            border-left: 3px solid #c53030;
        }

        .form-actions {
            display: flex;
            gap: 1rem;
            justify-content: flex-end;
            margin-top: 2.5rem;
            padding-top: 1.5rem;
            border-top: 2px solid var(--accent);
        }

        .btn {
            padding: 0.875rem 2rem;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            font-weight: 600;
            text-decoration: none;
            display: inline-block;
            transition: all 0.3s ease;
            font-size: 0.95rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--secondary), #c97642);
            color: white;
            box-shadow: 0 4px 10px rgba(223, 145, 82, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(223, 145, 82, 0.4);
        }

        .btn-secondary {
            background: var(--accent);
            color: var(--dark);
            border: 2px solid var(--primary);
        }

        .btn-secondary:hover {
            background: var(--primary);
            transform: translateY(-2px);
        }
    </style>
{% endblock %}

{% block body %}
    <div class="hero-section">
        <h1>Edit Profile</h1>
    </div>

    <div class="form-container">
        {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

            <div class="form-group">
                {{ form_label(form.username) }}
                {{ form_widget(form.username) }}
                {{ form_errors(form.username) }}
            </div>

            <div class="form-group">
                {{ form_label(form.email) }}
                {{ form_widget(form.email) }}
                {{ form_errors(form.email) }}
            </div>

            <div class="form-group">
                {{ form_label(form.fullName) }}
                {{ form_widget(form.fullName) }}
                {{ form_errors(form.fullName) }}
            </div>

            <div class="form-group">
                {{ form_label(form.bio) }}
                {{ form_widget(form.bio) }}
                {{ form_errors(form.bio) }}
            </div>

            <div class="form-group">
                {{ form_label(form.profilePictureFile) }}
                {{ form_widget(form.profilePictureFile) }}
                {{ form_errors(form.profilePictureFile) }}
                {% if user.profilePicture %}
                    <div class="current-picture">
                        <p style="font-size: 0.875rem; color: #666; margin: 0.5rem 0;">Current Picture:</p>
                        <img src="{{ user.profilePicture }}" alt="{{ user.fullName }}">
                    </div>
                {% endif %}
            </div>

            <div class="form-actions">
                <a href="{{ path('app_profile') }}" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>

        {{ form_end(form) }}
    </div>
{% endblock %}
