{% extends 'admin/base.html.twig' %}

{% block title %}Change Password | Cloudrobe Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --primary: #ecc9c9;
            --secondary: #df9152;
            --accent: #e5a3a3;
            --dark: #5c3a3a;
            --light: #fdf6f6;
        }

        .hero-section {
            background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
            color: white;
            padding: 2rem;
            text-align: center;
            box-shadow: 0 10px 30px rgba(229, 163, 163, 0.4);
            margin: -30px -30px 2rem -30px;
            width: calc(100% + 60px);
        }

        .hero-section h1 {
            font-size: 2.2rem;
            font-weight: 800;
            margin: 0;
            color: var(--dark);
        }

        .form-container {
            max-width: 600px;
            margin: 0 auto;
            background: white;
            padding: 2.5rem;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(92, 58, 58, 0.12);
        }

        .security-notice {
            background: #fef3c7;
            border-left: 4px solid #f59e0b;
            padding: 1rem 1.25rem;
            border-radius: 8px;
            margin-bottom: 2rem;
            color: #78350f;
        }

        .security-notice strong {
            display: block;
            margin-bottom: 0.5rem;
            font-size: 1.05rem;
        }

        .form-group {
            margin-bottom: 1.75rem;
        }

        label {
            display: block;
            font-weight: 600;
            margin-bottom: 0.625rem;
            color: var(--dark);
            font-size: 0.95rem;
        }

        input[type="password"] {
            width: 100%;
            padding: 0.875rem 1rem;
            border: 2px solid var(--accent);
            border-radius: 10px;
            font-size: 1rem;
            color: var(--dark);
            background-color: var(--light);
            transition: all 0.3s ease;
            box-sizing: border-box;
        }

        input[type="password"]:focus {
            outline: none;
            border-color: var(--secondary);
            background-color: white;
            box-shadow: 0 0 0 3px rgba(223, 145, 82, 0.15);
        }

        .form-errors {
            color: #c53030;
            font-size: 0.875rem;
            margin-top: 0.5rem;
            padding: 0.5rem;
            background-color: #fee;
            border-radius: 6px;
            border-left: 3px solid #c53030;
        }

        .password-requirements {
            font-size: 0.875rem;
            color: #666;
            margin-top: 0.5rem;
            padding-left: 1rem;
        }

        .password-requirements li {
            margin: 0.25rem 0;
        }

        .form-actions {
            display: flex;
            gap: 1rem;
            justify-content: flex-end;
            margin-top: 2.5rem;
            padding-top: 1.5rem;
            border-top: 2px solid var(--accent);
        }

        .btn {
            padding: 0.875rem 2rem;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            font-weight: 600;
            text-decoration: none;
            display: inline-block;
            transition: all 0.3s ease;
            font-size: 0.95rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--secondary), #c97642);
            color: white;
            box-shadow: 0 4px 10px rgba(223, 145, 82, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(223, 145, 82, 0.4);
        }

        .btn-secondary {
            background: var(--accent);
            color: var(--dark);
            border: 2px solid var(--primary);
        }

        .btn-secondary:hover {
            background: var(--primary);
            transform: translateY(-2px);
        }

        .alert {
            padding: 1rem 1.5rem;
            border-radius: 10px;
            margin-bottom: 1.5rem;
        }

        .alert-error {
            background: #fee2e2;
            color: #991b1b;
            border-left: 4px solid #dc2626;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="hero-section">
        <h1>🔒 Change Password</h1>
    </div>

    <div class="form-container">
        {% for message in app.flashes('error') %}
            <div class="alert alert-error">{{ message }}</div>
        {% endfor %}

        <div class="security-notice">
            <strong>🔐 Security Tip</strong>
            <p>Choose a strong password that you don't use on any other websites. Make sure it's at least 6 characters long.</p>
        </div>

        {{ form_start(form) }}

            <div class="form-group">
                {{ form_label(form.currentPassword) }}
                {{ form_widget(form.currentPassword) }}
                {{ form_errors(form.currentPassword) }}
            </div>

            <div class="form-group">
                {{ form_label(form.newPassword.first) }}
                {{ form_widget(form.newPassword.first) }}
                {{ form_errors(form.newPassword.first) }}
                <ul class="password-requirements">
                    <li>✓ At least 6 characters long</li>
                    <li>✓ Mix of letters, numbers, and symbols recommended</li>
                </ul>
            </div>

            <div class="form-group">
                {{ form_label(form.newPassword.second) }}
                {{ form_widget(form.newPassword.second) }}
                {{ form_errors(form.newPassword.second) }}
            </div>

            <div class="form-actions">
                <a href="{{ path('app_profile') }}" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">Update Password</button>
            </div>

        {{ form_end(form) }}
    </div>
{% endblock %}
