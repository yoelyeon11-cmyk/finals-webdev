<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Email Verification | Cloudrobe</title>
    <style>
        :root { --primary:#ecc9c9; --secondary:#df9152; --dark:#5c3a3a; --light:#fdf6f6; }
        *{ box-sizing:border-box; }
        body{ font-family:'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background:linear-gradient(135deg,var(--primary) 0%, #e5a3a3 100%); min-height:100vh; display:flex; align-items:center; justify-content:center; padding:20px; }
        .card{ background:#fff; width:100%; max-width:520px; padding:2.5rem; border-radius:20px; box-shadow:0 10px 40px rgba(92,58,58,.2); text-align:center; }
        h1{ color:var(--secondary); margin:0 0 10px; }
        p{ color:#666; margin:0 0 18px; }
        a{ display:inline-block; padding:12px 16px; border-radius:12px; background:linear-gradient(135deg,var(--secondary), #c97642); color:#fff; text-decoration:none; font-weight:700; }
        .muted{ margin-top:10px; color:#888; font-size:.95rem; }
    </style>
</head>
<body>
    <div class="card">
        {% if success %}
            <h1>Email verified</h1>
            <p>Your account has been verified successfully. You can now log in.</p>
        {% else %}
            <h1>Verification failed</h1>
            <p>This verification link is invalid or has expired.</p>
            <p class="muted">If you just registered, try registering again to get a new verification email.</p>
        {% endif %}
        <a href="{{ path('app_login') }}">Go to login</a>
    </div>
</body>
</html>

