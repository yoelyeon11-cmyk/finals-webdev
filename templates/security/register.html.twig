<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register | Cloudrobe</title>
    <style>
        :root { --primary:#ecc9c9; --secondary:#df9152; --dark:#5c3a3a; --light:#fdf6f6; }
        *{ box-sizing:border-box; }
        body{ font-family:'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background:linear-gradient(135deg,var(--primary) 0%, #e5a3a3 100%); min-height:100vh; display:flex; align-items:center; justify-content:center; padding:20px; }
        .card{ background:#fff; width:100%; max-width:520px; padding:2.5rem; border-radius:20px; box-shadow:0 10px 40px rgba(92,58,58,.2); }
        h1{ color:var(--secondary); margin:0 0 6px; }
        p{ color:#777; margin:0 0 20px; }
        .flash{ background:#fff; border-radius:10px; padding:12px 14px; margin-bottom:12px; border:1px solid #eee; }
        .flash.error{ border-left:4px solid #dc2626; }
        .flash.success{ border-left:4px solid #16a34a; }
        label{ display:block; font-weight:600; margin:14px 0 6px; color:var(--dark); }
        input{ width:100%; padding:12px 12px; border:2px solid var(--primary); border-radius:12px; background:var(--light); }
        input:focus{ outline:none; border-color:var(--secondary); background:#fff; box-shadow:0 0 0 3px rgba(223,145,82,.1); }
        button{ width:100%; margin-top:18px; padding:14px; background:linear-gradient(135deg,var(--secondary), #c97642); color:#fff; border:none; border-radius:12px; font-weight:700; cursor:pointer; }
        .links{ margin-top:14px; text-align:center; }
        .links a{ color:var(--dark); text-decoration:none; font-weight:600; }
    </style>
</head>
<body>
    <div class="card">
        <h1>Create account</h1>
        <p>We’ll email you a verification link after signup.</p>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash {{ label }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <form method="post" action="{{ path('app_register') }}" autocomplete="off">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" required>

            <label for="username">Username</label>
            <input id="username" name="username" type="text" required autocapitalize="none" spellcheck="false">

            <label for="fullName">Full name</label>
            <input id="fullName" name="fullName" type="text" required>

            <label for="password">Password</label>
            <input id="password" name="password" type="password" required autocomplete="new-password">

            <button type="submit">Register</button>
        </form>

        <div class="links">
            <a href="{{ path('app_login') }}">Back to login</a>
        </div>
    </div>
</body>
</html>

