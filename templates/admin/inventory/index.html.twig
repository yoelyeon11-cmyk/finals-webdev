{% extends 'admin/base.html.twig' %}

{% block title %}Inventory{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.dataTables.min.css">
    <style>
        :root {
            --primary: #e5a3a3;
            --secondary: #df9152;
            --accent: #ecc9c9;
            --dark: #5c3a3a;
            --light: #fdf6f6;
        }

        /* Layout uses global admin.css (same as Products tab) */

        .table {
            width: 100%;
            border-collapse: collapse;
        }

        .table thead {
            background: linear-gradient(135deg, var(--dark), #6b4545);
        }

        .table thead th {
            color: var(--light);
            padding: 1.25rem;
            text-align: left;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.875rem;
            letter-spacing: 0.5px;
        }

        .table tbody tr {
            border-bottom: 1px solid var(--accent);
            transition: background-color 0.2s ease;
        }

        .table tbody tr:hover {
            background-color: var(--accent);
        }

        .table tbody tr:last-child {
            border-bottom: none;
        }

        .table tbody td {
            padding: 1rem 1.25rem;
            color: var(--dark);
        }

        .table tbody td:first-child {
            font-weight: 600;
            color: var(--secondary);
        }

        .table tbody td:nth-child(2) {
            font-weight: 500;
        }

        .table tbody td:nth-child(3) {
            font-weight: 600;
            color: var(--primary);
        }

        .table tbody td:nth-child(4) {
            color: #8b6b6b;
            font-size: 0.9rem;
        }

        .empty-message {
            text-align: center;
            color: var(--dark);
            font-style: italic;
            opacity: 0.7;
        }

        /* DataTables Custom Styling */
        .dataTables_wrapper {
            padding: 1.5rem;
            background: white;
        }

        .dataTables_wrapper .dataTables_length,
        .dataTables_wrapper .dataTables_filter,
        .dataTables_wrapper .dataTables_info,
        .dataTables_wrapper .dataTables_paginate {
            color: var(--dark);
            padding: 12px 0;
        }

        .dataTables_wrapper .dataTables_filter {
            float: right;
        }

        .dataTables_wrapper .dataTables_filter label {
            font-weight: 500;
            color: var(--dark);
        }

        .dataTables_wrapper .dataTables_filter input {
            border: 2px solid var(--accent);
            border-radius: 8px;
            padding: 8px 12px;
            background: var(--light);
            color: var(--dark);
            margin-left: 8px;
            transition: border-color 0.3s ease;
        }

        .dataTables_wrapper .dataTables_filter input:focus {
            outline: none;
            border-color: var(--primary);
        }

        .dataTables_wrapper .dataTables_length label {
            font-weight: 500;
            color: var(--dark);
        }

        .dataTables_wrapper .dataTables_length select {
            border: 2px solid var(--accent);
            border-radius: 8px;
            padding: 6px 12px;
            background: var(--light);
            color: var(--dark);
            margin: 0 8px;
            transition: border-color 0.3s ease;
        }

        .dataTables_wrapper .dataTables_length select:focus {
            outline: none;
            border-color: var(--primary);
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            border: 2px solid var(--accent);
            background: var(--light);
            color: var(--dark) !important;
            border-radius: 6px;
            padding: 6px 12px;
            margin: 0 2px;
            transition: all 0.3s ease;
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
            background: var(--accent);
            border-color: var(--primary);
            color: var(--dark) !important;
            transform: translateY(-1px);
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button.current {
            background: linear-gradient(135deg, var(--secondary), var(--primary));
            border-color: var(--primary);
            color: white !important;
            font-weight: 600;
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button.current:hover {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white !important;
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button.disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        .dataTables_wrapper .dataTables_info {
            color: var(--dark);
            font-weight: 500;
            padding-top: 1rem;
        }

        table.dataTable thead .sorting,
        table.dataTable thead .sorting_asc,
        table.dataTable thead .sorting_desc {
            cursor: pointer;
            position: relative;
        }

        table.dataTable thead .sorting:after,
        table.dataTable thead .sorting_asc:after,
        table.dataTable thead .sorting_desc:after {
            opacity: 0.6;
            color: var(--light);
        }

        table.dataTable tbody tr {
            transition: all 0.2s ease;
        }

        table.dataTable.no-footer {
            border-bottom: 2px solid var(--primary);
        }
    </style>
{% endblock %}

{% block body %}
    <div class="header">
        <h2>Inventory</h2>
        <a class="btn btn-primary" href="{{ path('admin_inventory_add') }}">Add Stock</a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">
            {{ message }}
        </div>
    {% endfor %}

    <div class="table-wrapper table-section">
        <table id="inventoryTable" class="table display responsive nowrap" style="width:100%">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Total Stock Added</th>
                    <th>Last Added</th>
                </tr>
            </thead>
            <tbody>
            {% for entry in entries %}
                <tr>
                    <td>{{ entry.product.name }}</td>
                    <td data-order="{{ entry.totalQuantity }}">{{ entry.totalQuantity }}</td>
                    <td data-order="{{ entry.lastAdded|date('U') }}">{{ entry.lastAdded|date('Y-m-d H:i') }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
    <script>
        $(document).ready(function() {
            const table = $('#inventoryTable').DataTable({
                responsive: true,
                pageLength: 25,
                order: [[2, 'desc']],
                columnDefs: [
                    { targets: 0, width: '200px' },
                    { targets: 1, width: '150px' },
                ],
                language: {
                    search: "Search inventory:",
                    lengthMenu: "Show _MENU_ entries per page",
                    info: "Showing _START_ to _END_ of _TOTAL_ entries",
                    emptyTable: "No inventory entries found",
                    zeroRecords: "No matching inventory entries found",
                }
            });

            if (window.AdminRealtime) {
                window.AdminRealtime.syncDataTable({
                    table: table,
                    syncUrl: '{{ path("admin_realtime_inventory_json") }}',
                    fingerprintKey: 'inventoryFingerprint',
                    initialFingerprint: '{{ inventoryFingerprint|default("") }}',
                    eventTypes: [
                        'inventory.updated',
                        'product.updated',
                        'product.created',
                        'product.deleted',
                    ],
                    buildRows: function (rows) {
                        return rows.map(function (row) {
                            return [
                                window.AdminRealtime.escapeHtml(row.productName) + ' (stock: ' + window.AdminRealtime.escapeHtml(row.currentStock) + ')',
                                String(row.totalQuantity),
                                window.AdminRealtime.escapeHtml(row.lastAdded),
                            ];
                        });
                    },
                });
            }
        });
    </script>
{% endblock %}