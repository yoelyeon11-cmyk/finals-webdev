{% extends 'admin/base.html.twig' %}

{% block title %}Products{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .card-body .meta {
            display: block !important;
        }
        .card-body .meta span {
            display: block;
            margin-bottom: 10px;
            line-height: 1.5;
            font-weight: 500;
        }
        .card-body .meta span strong {
            color: #df9152;
            font-weight: 700;
            font-size: 1.1em;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="header">
        <h2>Products</h2>
        <a class="btn btn-primary" href="{{ path('admin_product_new') }}">New Product</a>
    </div>

    {% if products is not empty %}
        <div class="cards-grid">
            {% for product in products %}
                <div class="card-item">
                    <div class="card-thumb">
                        {% if product.image %}
                            <img src="{{ product.image }}" alt="{{ product.name }}">
                        {% else %}
                            <div class="placeholder">📦</div>
                        {% endif %}
                    </div>
                    <div class="card-body">
                        <div class="card-title">{{ product.name }}</div>
                        <div class="meta">
                            <span>Price: ${{ product.price|number_format(2) }}</span>
                            <span>Stock: <strong>{{ product.stock ?? 0 }}</strong></span>
                            <span>{{ product.category ? product.category.name : 'No Category' }}</span>
                        </div>
                        <div class="actions">
                            <a href="{{ path('admin_product_show', {'id': product.id}) }}" class="btn">View</a>
                            <a href="{{ path('admin_product_edit', {'id': product.id}) }}" class="btn">Edit</a>
                            <form method="post" action="{{ path('admin_product_delete', {'id': product.id}) }}" onsubmit="return confirm('Delete this product?');" style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                                <button type="submit" class="btn btn-danger">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="empty">
            <p>No products found.</p>
        </div>
    {% endif %}
{% endblock %}
