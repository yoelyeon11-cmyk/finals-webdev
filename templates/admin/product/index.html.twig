{% extends 'admin/base.html.twig' %}

{% block title %}Products{% endblock %}

{% block body %}
    <div class="header">
        <h2>Products</h2>
        <a class="btn btn-primary" href="{{ path('admin_product_new') }}">New Product</a>
    </div>

    <div id="productsGrid" class="cards-grid">
        {% for product in products %}
            <div class="card-item product-card" data-product-id="{{ product.id }}">
                <div class="card-thumb">
                    {% if product.image %}
                        <img src="{{ product_image_url(product.image) }}" alt="{{ product.name }}">
                    {% else %}
                        <div class="placeholder">📦</div>
                    {% endif %}
                </div>
                <div class="card-body">
                    <div class="card-title">{{ product.name }}</div>
                    <dl class="product-meta">
                        <div class="product-meta-row">
                            <dt>Category</dt>
                            <dd>{{ product.category ? product.category.name : 'No Category' }}</dd>
                        </div>
                        <div class="product-meta-row">
                            <dt>Stock</dt>
                            <dd class="stock-value">{{ product.stock ?? 0 }}</dd>
                        </div>
                        <div class="product-meta-row">
                            <dt>Status</dt>
                            <dd>
                                {% set stock = product.stock ?? 0 %}
                                {% if stock > 20 %}
                                    <span class="stock-badge in-stock">In Stock</span>
                                {% elseif stock > 0 %}
                                    <span class="stock-badge low-stock">Low Stock</span>
                                {% else %}
                                    <span class="stock-badge out-of-stock">Out of Stock</span>
                                {% endif %}
                            </dd>
                        </div>
                        <div class="product-meta-row">
                            <dt>Price</dt>
                            <dd>₱{{ product.price|number_format(2) }}</dd>
                        </div>
                    </dl>
                    <div class="actions">
                        <a href="{{ path('admin_product_show', {'id': product.id}) }}" class="btn">View</a>
                        <a href="{{ path('admin_product_edit', {'id': product.id}) }}" class="btn">Edit</a>
                        <form method="post" action="{{ path('admin_product_delete', {'id': product.id}) }}" onsubmit="return confirm('Delete this product?');" style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    <div id="productsEmpty" class="empty" {% if products is not empty %}style="display:none"{% endif %}>
        <p>No products found.</p>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
    (function () {
        let pollTimer = null;
        let unsubscribeRealtime = null;
        let syncInFlight = false;
        let knownProductsFingerprint = '{{ productsFingerprint|default("") }}';
        const cardsJsonUrl = '{{ path("admin_product_cards_json") }}';
        const rowJsonUrlTemplate = '{{ path("admin_product_row_json", {id: 0})|replace({"0": "__ID__"}) }}';
        const PRODUCT_EVENT_TYPES = [
            'product.created',
            'product.updated',
            'product.deleted',
            'inventory.updated',
            'fingerprint.changed',
        ];

        function escapeHtml(value) {
            return String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;');
        }

        function rowJsonUrl(productId) {
            return rowJsonUrlTemplate.replace('__ID__', String(productId));
        }

        function stockBadgeHtml(stock) {
            const value = Number(stock || 0);
            if (value > 20) {
                return '<span class="stock-badge in-stock">In Stock</span>';
            }
            if (value > 0) {
                return '<span class="stock-badge low-stock">Low Stock</span>';
            }
            return '<span class="stock-badge out-of-stock">Out of Stock</span>';
        }

        function highlightCard(node) {
            if (!node) {
                return;
            }
            node.classList.add('product-live-highlight');
            window.setTimeout(function () {
                node.classList.remove('product-live-highlight');
            }, 2300);
        }

        function buildCardHtml(card) {
            const stock = Number(card.stock || 0);
            const imageHtml = card.imageUrl
                ? '<img src="' + escapeHtml(card.imageUrl) + '" alt="' + escapeHtml(card.name) + '">'
                : '<div class="placeholder">📦</div>';

            return ''
                + '<div class="card-thumb">' + imageHtml + '</div>'
                + '<div class="card-body">'
                + '<div class="card-title">' + escapeHtml(card.name) + '</div>'
                + '<dl class="product-meta">'
                + '<div class="product-meta-row"><dt>Category</dt><dd>' + escapeHtml(card.categoryName) + '</dd></div>'
                + '<div class="product-meta-row"><dt>Stock</dt><dd class="stock-value">' + escapeHtml(stock) + '</dd></div>'
                + '<div class="product-meta-row"><dt>Status</dt><dd>' + stockBadgeHtml(stock) + '</dd></div>'
                + '<div class="product-meta-row"><dt>Price</dt><dd>₱' + escapeHtml(card.price) + '</dd></div>'
                + '</dl>'
                + '<div class="actions">'
                + '<a href="' + escapeHtml(card.showUrl) + '" class="btn">View</a>'
                + '<a href="' + escapeHtml(card.editUrl) + '" class="btn">Edit</a>'
                + '<form method="post" action="' + escapeHtml(card.deleteUrl) + '" onsubmit="return confirm(\'Delete this product?\');" style="display:inline;">'
                + '<input type="hidden" name="_token" value="' + escapeHtml(card.deleteToken) + '">'
                + '<button type="submit" class="btn btn-danger">Delete</button>'
                + '</form>'
                + '</div>'
                + '</div>';
        }

        function upsertProductCard(card) {
            const grid = document.getElementById('productsGrid');
            const empty = document.getElementById('productsEmpty');
            if (!grid) {
                return;
            }

            let node = grid.querySelector('[data-product-id="' + String(card.id) + '"]');
            if (!node) {
                node = document.createElement('div');
                node.className = 'card-item product-card';
                node.setAttribute('data-product-id', String(card.id));
                grid.prepend(node);
            }

            node.innerHTML = buildCardHtml(card);
            highlightCard(node);

            if (empty) {
                empty.style.display = grid.children.length ? 'none' : '';
            }
        }

        function removeProductCard(productId) {
            const grid = document.getElementById('productsGrid');
            const empty = document.getElementById('productsEmpty');
            if (!grid) {
                return;
            }
            const node = grid.querySelector('[data-product-id="' + String(productId) + '"]');
            if (node) {
                node.remove();
            }
            if (empty) {
                empty.style.display = grid.children.length ? 'none' : '';
            }
        }

        function applyProductCards(cards) {
            const grid = document.getElementById('productsGrid');
            const empty = document.getElementById('productsEmpty');
            if (!grid) {
                return;
            }
            const seen = new Set();
            (cards || []).forEach(function (card) {
                seen.add(Number(card.id));
                upsertProductCard(card);
            });
            Array.from(grid.querySelectorAll('[data-product-id]')).forEach(function (node) {
                const id = Number(node.getAttribute('data-product-id'));
                if (!seen.has(id)) {
                    node.remove();
                }
            });
            if (empty) {
                empty.style.display = grid.children.length ? 'none' : '';
            }
        }

        async function fetchAndUpsertProduct(productId) {
            if (!productId) {
                return;
            }
            try {
                const res = await fetch(rowJsonUrl(productId), {
                    credentials: 'include',
                    headers: { Accept: 'application/json' },
                    cache: 'no-store',
                });
                if (!res.ok) {
                    return;
                }
                const payload = await res.json();
                if (payload?.success && payload?.data) {
                    upsertProductCard(payload.data);
                }
            } catch (e) {
                // silent fallback
            }
        }

        async function syncAllProductCards() {
            if (syncInFlight) {
                return;
            }
            syncInFlight = true;
            try {
                const res = await fetch(cardsJsonUrl, {
                    credentials: 'include',
                    headers: { Accept: 'application/json' },
                    cache: 'no-store',
                });
                if (!res.ok) {
                    return;
                }
                const payload = await res.json();
                const data = payload?.data;
                if (!payload?.success || !data) {
                    return;
                }
                knownProductsFingerprint = data.fingerprint || knownProductsFingerprint;
                if (window.AdminRealtime?.seedFingerprints) {
                    window.AdminRealtime.seedFingerprints({
                        productsFingerprint: knownProductsFingerprint,
                    });
                }
                applyProductCards(data.cards || []);
            } catch (e) {
                // silent fallback
            } finally {
                syncInFlight = false;
            }
        }

        async function pollProductCards() {
            try {
                const res = await fetch(cardsJsonUrl, {
                    credentials: 'include',
                    headers: { Accept: 'application/json' },
                    cache: 'no-store',
                });
                if (!res.ok) {
                    return;
                }
                const payload = await res.json();
                const data = payload?.data;
                if (!payload?.success || !data) {
                    return;
                }
                const serverFingerprint = String(data.fingerprint || '');
                if (serverFingerprint && serverFingerprint !== knownProductsFingerprint) {
                    knownProductsFingerprint = serverFingerprint;
                    if (window.AdminRealtime?.seedFingerprints) {
                        window.AdminRealtime.seedFingerprints({ productsFingerprint: serverFingerprint });
                    }
                    applyProductCards(data.cards || []);
                }
            } catch (e) {
                // silent fallback
            }
        }

        function shouldRefreshProducts(event) {
            const type = event?.type || '';
            if (type === 'fingerprint.changed') {
                const key = event?.payload?.key;
                return key === 'productsFingerprint' || key === 'inventoryFingerprint' || key === 'dashboardFingerprint';
            }
            return PRODUCT_EVENT_TYPES.includes(type);
        }

        async function handleRealtimeEvent(event) {
            if (!shouldRefreshProducts(event)) {
                return;
            }

            const type = event?.type;
            const productId = Number(event?.payload?.productId || 0);

            if (type === 'product.deleted' && productId) {
                removeProductCard(productId);
                return;
            }

            if ((type === 'product.updated' || type === 'inventory.updated') && productId) {
                await fetchAndUpsertProduct(productId);
                return;
            }

            await syncAllProductCards();
        }

        function teardownLiveProducts() {
            if (pollTimer) {
                clearInterval(pollTimer);
                pollTimer = null;
            }
            if (typeof unsubscribeRealtime === 'function') {
                unsubscribeRealtime();
                unsubscribeRealtime = null;
            }
        }

        function initLiveProducts() {
            const grid = document.getElementById('productsGrid');
            if (!grid) {
                return;
            }

            teardownLiveProducts();

            if (window.AdminRealtime) {
                window.AdminRealtime.seedFingerprints({
                    productsFingerprint: knownProductsFingerprint,
                });
                unsubscribeRealtime = window.AdminRealtime.subscribe(handleRealtimeEvent);
            }
            window.addEventListener('admin:realtime', function (event) {
                handleRealtimeEvent(event.detail);
            });

            pollProductCards();
            pollTimer = setInterval(function () {
                if (!document.hidden) {
                    pollProductCards();
                }
            }, 1000);
        }

        document.addEventListener('DOMContentLoaded', initLiveProducts);
        document.addEventListener('turbo:load', initLiveProducts);
        document.addEventListener('turbo:before-cache', teardownLiveProducts);
    })();
    </script>
{% endblock %}
