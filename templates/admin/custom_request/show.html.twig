{% extends 'admin/base.html.twig' %}

{% block title %}Custom Request #{{ request.id }}{% endblock %}

{% block body %}
<div class="header">
    <h2>🎭 Custom Request #{{ request.id }}</h2>
    <div>
        {% if is_granted('ROLE_ADMIN') and request.status == 'awaiting_approval' %}
            <form method="post" action="{{ path('admin_custom_request_verify', {id: request.id}) }}" style="display: inline;">
                <button type="submit" class="btn btn-success" onclick="return confirm('Verify and approve this request?')">
                    ✓ Verify & Approve
                </button>
            </form>
        {% endif %}
        {% if request.status == 'approved' and request.status != 'converted_to_order' %}
            <a href="{{ path('admin_custom_request_convert', {id: request.id}) }}" class="btn btn-primary">
                📦 Convert to Order
            </a>
        {% endif %}
        <a href="{{ path('admin_custom_request_edit', {id: request.id}) }}" class="btn btn-secondary">Edit</a>
        <a href="{{ path('admin_custom_request_index') }}" class="btn btn-secondary">← Back</a>
    </div>
</div>

<div class="details-grid">
    <div class="card">
        <h3>Customer Information</h3>
        <table class="details-table">
            <tr>
                <th>Name:</th>
                <td>{{ request.customerName }}</td>
            </tr>
            <tr>
                <th>Email:</th>
                <td>{{ request.customerEmail }}</td>
            </tr>
            <tr>
                <th>Phone:</th>
                <td>{{ request.customerPhone|default('N/A') }}</td>
            </tr>
        </table>
    </div>

    <div class="card">
        <h3>Request Status</h3>
        <table class="details-table">
            <tr>
                <th>Status:</th>
                <td>
                    <span class="badge badge-{{ request.status == 'approved' ? 'success' : (request.status == 'rejected' ? 'danger' : 'warning') }}">
                        {{ request.statusLabel }}
                    </span>
                </td>
            </tr>
            <tr>
                <th>Estimated Cost:</th>
                <td>
                    {% if request.estimatedCost %}
                        <strong style="color: var(--secondary); font-size: 18px;">${{ request.estimatedCost }}</strong>
                    {% else %}
                        <em>Not quoted yet</em>
                    {% endif %}
                </td>
            </tr>
            <tr>
                <th>Created:</th>
                <td>{{ request.createdAt|date('F d, Y h:i A') }}</td>
            </tr>
            <tr>
                <th>Created By:</th>
                <td>{{ request.createdBy ? request.createdBy.fullName : 'System' }}</td>
            </tr>
        </table>
    </div>
</div>

<div class="card">
    <h3>Cosplay Details</h3>
    <table class="details-table">
        <tr>
            <th style="width: 200px;">Character/Subject:</th>
            <td><strong>{{ request.cosplayCharacter }}</strong></td>
        </tr>
        <tr>
            <th>Design & Material Notes:</th>
            <td>{{ request.designNotes|nl2br|default('No additional notes') }}</td>
        </tr>
    </table>
</div>

<div class="card">
    <h3>Measurements</h3>
    <div class="measurement-grid">
        <div class="measurement-item">
            <label>Bust</label>
            <span>{{ request.bust ? request.bust ~ '"' : 'N/A' }}</span>
        </div>
        <div class="measurement-item">
            <label>Waist</label>
            <span>{{ request.waist ? request.waist ~ '"' : 'N/A' }}</span>
        </div>
        <div class="measurement-item">
            <label>Hip</label>
            <span>{{ request.hip ? request.hip ~ '"' : 'N/A' }}</span>
        </div>
        <div class="measurement-item">
            <label>Shoulder Width</label>
            <span>{{ request.shoulderWidth ? request.shoulderWidth ~ '"' : 'N/A' }}</span>
        </div>
        <div class="measurement-item">
            <label>Inseam</label>
            <span>{{ request.inseam ? request.inseam ~ '"' : 'N/A' }}</span>
        </div>
        <div class="measurement-item">
            <label>Height</label>
            <span>{{ request.height ? request.height ~ '"' : 'N/A' }}</span>
        </div>
    </div>
    {% if request.customMeasurements %}
    <div style="margin-top: 20px;">
        <strong>Additional Measurements:</strong>
        <p>{{ request.customMeasurements|nl2br }}</p>
    </div>
    {% endif %}
</div>

<style>
.measurement-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 15px;
    margin-top: 15px;
}

.measurement-item {
    padding: 15px;
    background: var(--light);
    border-radius: 8px;
    text-align: center;
}

.measurement-item label {
    display: block;
    font-size: 12px;
    color: #666;
    margin-bottom: 5px;
    font-weight: 600;
}

.measurement-item span {
    display: block;
    font-size: 20px;
    font-weight: 700;
    color: var(--secondary);
}
</style>
{% endblock %}
