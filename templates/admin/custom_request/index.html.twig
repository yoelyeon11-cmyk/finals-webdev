{% extends 'admin/base.html.twig' %}

{% block title %}Custom Cosplay Requests{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.dataTables.min.css">
    <style>
        :root {
            --primary: #ecc9c9;
            --secondary: #df9152;
            --accent: #e5a3a3;
            --dark: #2c2c2c;
            --light: #f8f9fa;
        }

        /* Layout uses global admin.css (same as Products tab) */

        table.dataTable {
            width: 100%;
            border-collapse: collapse;
        }

        table.dataTable thead {
            background: linear-gradient(135deg, var(--primary), var(--accent));
        }

        table.dataTable thead th {
            padding: 1.2rem 1.5rem;
            text-align: left;
            font-weight: 600;
            color: var(--dark);
            border-bottom: none;
        }

        table.dataTable tbody tr {
            border-bottom: 1px solid #f0f0f0;
            transition: background 0.2s;
        }

        table.dataTable tbody tr:hover {
            background: var(--light);
        }

        table.dataTable tbody tr.request-live-highlight {
            animation: requestLiveHighlight 2.2s ease;
        }

        @keyframes requestLiveHighlight {
            0% { background-color: #fff3cd; }
            100% { background-color: transparent; }
        }

        table.dataTable tbody td {
            padding: 1.2rem 1.5rem;
            color: #666;
        }

        .badge {
            padding: 0.35rem 0.75rem;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
            display: inline-block;
            margin: 0.2rem;
        }

        .badge-success { background: #10b981; color: white; }
        .badge-danger { background: #ef4444; color: white; }
        .badge-warning { background: #f59e0b; color: white; }

        .action-buttons {
            display: flex;
            gap: 0.5rem;
        }

        .btn-action {
            padding: 0.5rem;
            border-radius: 8px;
            background: var(--primary);
            color: var(--dark);
            text-decoration: none;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-action:hover {
            background: var(--accent);
            transform: translateY(-1px);
        }

        .btn-action svg {
            width: 18px;
            height: 18px;
        }

        .dataTables_wrapper .dataTables_length,
        .dataTables_wrapper .dataTables_filter,
        .dataTables_wrapper .dataTables_info,
        .dataTables_wrapper .dataTables_paginate {
            padding: 1rem 1.5rem;
        }

        .dataTables_wrapper .dataTables_filter input {
            border: 2px solid var(--primary);
            border-radius: 8px;
            padding: 0.5rem 1rem;
        }

        .dataTables_wrapper .dataTables_length select {
            border: 2px solid var(--primary);
            border-radius: 8px;
            padding: 0.5rem;
        }
    </style>
{% endblock %}

{% block body %}
<div class="header">
    <h2>Custom Cosplay Requests</h2>
    <a href="{{ path('admin_custom_request_new') }}" class="btn btn-primary">
        <svg fill="currentColor" viewBox="0 0 20 20" style="width: 16px; height: 16px; margin-right: 4px;">
            <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"></path>
        </svg>
        New Request
    </a>
</div>

<div class="requests-table table-section">
    <table id="requestsTable" class="display responsive nowrap" style="width:100%">
        <thead>
            <tr>
                <th>ID</th>
                <th>Customer</th>
                <th>Character/Subject</th>
                <th>Estimated Cost</th>
                <th>Status</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for request in requests %}
            <tr data-request-id="{{ request.id }}">
                <td>#{{ request.id }}</td>
                <td>
                    <strong>{{ request.customerName }}</strong><br>
                    <small>{{ request.customerEmail }}</small>
                </td>
                <td>{{ request.cosplayCharacter }}</td>
                <td>
                    {% if request.estimatedCost %}
                        <strong>₱{{ request.estimatedCost }}</strong>
                    {% else %}
                        <em>Not quoted</em>
                    {% endif %}
                </td>
                <td>
                    <span class="badge badge-{{ request.status == 'approved' ? 'success' : (request.status == 'rejected' ? 'danger' : 'warning') }}">
                        {{ request.statusLabel }}
                    </span>
                </td>
                <td>{{ request.createdAt|date('M d, Y') }}</td>
                <td>
                    <div class="action-buttons">
                        <a href="{{ path('admin_custom_request_show', {id: request.id}) }}" class="btn-action" title="View Details">
                            <svg fill="currentColor" viewBox="0 0 20 20"><path d="M10 12a2 2 0 100-4 2 2 0 000 4z"></path><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"></path></svg>
                        </a>
                        <a href="{{ path('admin_custom_request_edit', {id: request.id}) }}" class="btn-action" title="Edit">
                            <svg fill="currentColor" viewBox="0 0 20 20"><path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"></path></svg>
                        </a>
                    </div>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
    <script>
    (function () {
        let liveTimer = null;
        let requestWs = null;
        const LIVE_CHECK_MS = 1000;
        let knownLatestRequestId = Number('{{ latestRequestId ?? 0 }}') || 0;
        const websocketUrl = '{{ websocketUrl|default("") }}';
        const rowJsonUrlTemplate = '{{ path("admin_custom_request_row_json", {id: 0})|replace({"0": "__ID__"}) }}';
        const viewIconSvg = '<svg fill="currentColor" viewBox="0 0 20 20"><path d="M10 12a2 2 0 100-4 2 2 0 000 4z"></path><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"></path></svg>';
        const editIconSvg = '<svg fill="currentColor" viewBox="0 0 20 20"><path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"></path></svg>';

        function escapeHtml(value) {
            return String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;');
        }

        function rowJsonUrl(requestId) {
            return rowJsonUrlTemplate.replace('__ID__', String(requestId));
        }

        function buildRowData(request) {
            const costCell = request.estimatedCost
                ? '<strong>₱' + escapeHtml(request.estimatedCost) + '</strong>'
                : '<em>Not quoted</em>';
            const statusCell = '<span class="badge badge-' + escapeHtml(request.statusBadgeClass) + '">' + escapeHtml(request.statusLabel) + '</span>';

            return [
                '#' + escapeHtml(request.id),
                '<strong>' + escapeHtml(request.customerName) + '</strong><br><small>' + escapeHtml(request.customerEmail) + '</small>',
                escapeHtml(request.cosplayCharacter),
                costCell,
                statusCell,
                escapeHtml(request.createdAt),
                '<div class="action-buttons">'
                    + '<a href="' + escapeHtml(request.showUrl) + '" class="btn-action" title="View Details">' + viewIconSvg + '</a>'
                    + '<a href="' + escapeHtml(request.editUrl) + '" class="btn-action" title="Edit">' + editIconSvg + '</a>'
                    + '</div>',
            ];
        }

        function highlightRow(node) {
            if (!node) {
                return;
            }
            node.classList.add('request-live-highlight');
            window.setTimeout(function () {
                node.classList.remove('request-live-highlight');
            }, 2300);
        }

        function teardownLiveRequestUpdates() {
            if (liveTimer) {
                clearInterval(liveTimer);
                liveTimer = null;
            }
            if (requestWs) {
                requestWs.close();
                requestWs = null;
            }
        }

        function initCustomRequestLiveTable() {
            if (typeof window.$ === 'undefined') {
                return;
            }
            const tableEl = $('#requestsTable');
            if (!tableEl.length) {
                return;
            }

            teardownLiveRequestUpdates();

            if ($.fn.DataTable.isDataTable('#requestsTable')) {
                $('#requestsTable').DataTable().destroy();
            }

            const table = tableEl.DataTable({
                responsive: true,
                order: [[5, 'desc']],
                pageLength: 25,
                language: {
                    search: "Search requests:",
                    lengthMenu: "Show _MENU_ requests per page",
                    info: "Showing _START_ to _END_ of _TOTAL_ requests",
                    emptyTable: "No custom requests found",
                    zeroRecords: "No matching requests found"
                }
            });

            function findRowByRequestId(requestId) {
                let match = null;
                table.rows().every(function () {
                    const node = this.node();
                    if (node && String(node.getAttribute('data-request-id')) === String(requestId)) {
                        match = this;
                    }
                });
                return match;
            }

            function upsertRequestRow(request) {
                const rowData = buildRowData(request);
                const existing = findRowByRequestId(request.id);

                if (existing) {
                    existing.data(rowData);
                    table.order([[5, 'desc']]).draw(false);
                    highlightRow(existing.node());
                    return;
                }

                const added = table.row.add(rowData);
                const node = added.node();
                if (node) {
                    node.setAttribute('data-request-id', String(request.id));
                    highlightRow(node);
                }
                table.order([[5, 'desc']]).draw(false);
            }

            async function fetchAndUpsertRequest(requestId) {
                if (!requestId) {
                    return;
                }
                try {
                    const res = await fetch(rowJsonUrl(requestId), {
                        credentials: 'include',
                        headers: { Accept: 'application/json' },
                    });
                    if (!res.ok) {
                        return;
                    }
                    const payload = await res.json();
                    if (payload?.success && payload?.data) {
                        upsertRequestRow(payload.data);
                    }
                } catch (e) {
                    // silent fallback
                }
            }

            async function syncMissingRequests(latestId) {
                if (!latestId || latestId <= knownLatestRequestId) {
                    return;
                }
                for (let id = knownLatestRequestId + 1; id <= latestId; id += 1) {
                    await fetchAndUpsertRequest(id);
                }
                knownLatestRequestId = latestId;
            }

            async function handleRealtimeEvent(event) {
                const type = event?.type;
                if (type !== 'custom_request.created' && type !== 'custom_request.updated') {
                    return;
                }
                const requestId = Number(event?.payload?.requestId || 0);
                if (requestId) {
                    await fetchAndUpsertRequest(requestId);
                    knownLatestRequestId = Math.max(knownLatestRequestId, requestId);
                    return;
                }
                await pollLiveUpdates();
            }

            async function pollLiveUpdates() {
                try {
                    const res = await fetch('{{ path("admin_realtime_updates") }}', {
                        credentials: 'include',
                        headers: { Accept: 'application/json' },
                    });
                    if (!res.ok) {
                        return;
                    }
                    const payload = await res.json();
                    const serverLatestRequestId = Number(payload?.data?.latestCustomRequestId || 0);
                    await syncMissingRequests(serverLatestRequestId);
                } catch (e) {
                    // silent fallback
                }
            }

            liveTimer = setInterval(function () {
                if (!document.hidden) {
                    pollLiveUpdates();
                }
            }, LIVE_CHECK_MS);

            if (websocketUrl) {
                try {
                    requestWs = new WebSocket(websocketUrl);
                    requestWs.onmessage = function (message) {
                        try {
                            const event = JSON.parse(message.data || '{}');
                            handleRealtimeEvent(event);
                        } catch (e) {
                            // ignore malformed websocket payloads
                        }
                    };
                } catch (e) {
                    // fallback polling remains active
                }
            }
        }

        document.addEventListener('DOMContentLoaded', initCustomRequestLiveTable);
        document.addEventListener('turbo:load', initCustomRequestLiveTable);
        document.addEventListener('turbo:before-cache', teardownLiveRequestUpdates);
    })();
    </script>
{% endblock %}
