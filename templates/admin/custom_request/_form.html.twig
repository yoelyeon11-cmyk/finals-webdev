{{ form_start(form) }}

<div class="form-section">
    <h3>Customer Information</h3>
    <div class="form-row">
        <div class="form-group">
            {{ form_label(form.customerName) }}
            {{ form_widget(form.customerName) }}
            {{ form_errors(form.customerName) }}
        </div>
    </div>
    <div class="form-row">
        <div class="form-group">
            {{ form_label(form.customerEmail) }}
            {{ form_widget(form.customerEmail) }}
            {{ form_errors(form.customerEmail) }}
        </div>
        <div class="form-group">
            {{ form_label(form.customerPhone) }}
            {{ form_widget(form.customerPhone) }}
            {{ form_errors(form.customerPhone) }}
        </div>
    </div>
</div>

<div class="form-section">
    <h3>Cosplay Details</h3>
    <div class="form-row">
        <div class="form-group">
            {{ form_label(form.cosplayCharacter) }}
            {{ form_widget(form.cosplayCharacter) }}
            {{ form_errors(form.cosplayCharacter) }}
        </div>
    </div>
    <div class="form-row">
        <div class="form-group">
            {{ form_label(form.designNotes) }}
            {{ form_widget(form.designNotes) }}
            {{ form_errors(form.designNotes) }}
        </div>
    </div>
</div>

<div class="form-section">
    <h3>Measurements (in inches)</h3>
    <div class="form-row">
        <div class="form-group">
            {{ form_label(form.bust) }}
            {{ form_widget(form.bust) }}
            {{ form_errors(form.bust) }}
        </div>
        <div class="form-group">
            {{ form_label(form.waist) }}
            {{ form_widget(form.waist) }}
            {{ form_errors(form.waist) }}
        </div>
        <div class="form-group">
            {{ form_label(form.hip) }}
            {{ form_widget(form.hip) }}
            {{ form_errors(form.hip) }}
        </div>
    </div>
    <div class="form-row">
        <div class="form-group">
            {{ form_label(form.shoulderWidth) }}
            {{ form_widget(form.shoulderWidth) }}
            {{ form_errors(form.shoulderWidth) }}
        </div>
        <div class="form-group">
            {{ form_label(form.inseam) }}
            {{ form_widget(form.inseam) }}
            {{ form_errors(form.inseam) }}
        </div>
        <div class="form-group">
            {{ form_label(form.height) }}
            {{ form_widget(form.height) }}
            {{ form_errors(form.height) }}
        </div>
    </div>
    <div class="form-row">
        <div class="form-group">
            {{ form_label(form.customMeasurements) }}
            {{ form_widget(form.customMeasurements) }}
            {{ form_errors(form.customMeasurements) }}
        </div>
    </div>
</div>

<div class="form-section">
    <h3>{{ form.status is defined ? 'Quote & Status' : 'Quote' }}</h3>
    <div class="form-row">
        <div class="form-group">
            {{ form_label(form.estimatedCost) }}
            {{ form_widget(form.estimatedCost) }}
            {{ form_errors(form.estimatedCost) }}
        </div>
        {% if form.status is defined %}
            <div class="form-group">
                {{ form_label(form.status) }}
                {{ form_widget(form.status) }}
                {{ form_errors(form.status) }}
            </div>
        {% endif %}
    </div>
</div>

<div class="form-actions">
    <button type="submit" class="btn btn-primary">{{ button_label|default('Save') }}</button>
    <a href="{{ path('admin_custom_request_index') }}" class="btn btn-secondary">Cancel</a>
</div>

{{ form_end(form) }}
