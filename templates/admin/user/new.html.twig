{% extends 'admin/base.html.twig' %}

{% block title %}Add New User | Cloudrobe Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --primary: #ecc9c9;
            --secondary: #df9152;
            --accent: #e5a3a3;
            --dark: #5c3a3a;
            --light: #fdf6f6;
        }

        .hero-section {
            background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
            color: white;
            padding: 2rem;
            text-align: center;
            box-shadow: 0 10px 30px rgba(229, 163, 163, 0.4);
            margin: -30px -30px 2rem -30px;
            width: calc(100% + 60px);
        }

        .hero-section h1 {
            font-size: 2.2rem;
            font-weight: 800;
            margin: 0;
            color: var(--dark);
        }

        .form-container {
            max-width: 600px;
            margin: 0 auto;
            background: white;
            padding: 2.5rem;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(92, 58, 58, 0.12);
        }

        .form-group {
            margin-bottom: 1.75rem;
        }

        label {
            display: block;
            font-weight: 600;
            margin-bottom: 0.625rem;
            color: var(--dark);
            font-size: 0.95rem;
        }

        input[type="text"],
        input[type="email"],
        input[type="password"] {
            width: 100%;
            padding: 0.875rem 1rem;
            border: 2px solid var(--accent);
            border-radius: 10px;
            font-size: 1rem;
            color: var(--dark);
            background-color: var(--light);
            transition: all 0.3s ease;
            box-sizing: border-box;
        }

        input[type="text"]:focus,
        input[type="email"]:focus,
        input[type="password"]:focus {
            outline: none;
            border-color: var(--secondary);
            background-color: white;
            box-shadow: 0 0 0 3px rgba(223, 145, 82, 0.15);
        }

        .form-help {
            font-size: 0.875rem;
            color: #8b6b6b;
            margin-top: 0.375rem;
            font-style: italic;
        }

        .role-checkboxes {
            display: flex;
            gap: 1.5rem;
            margin-top: 0.5rem;
        }

        .role-option {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .role-option input[type="checkbox"] {
            width: 20px;
            height: 20px;
            cursor: pointer;
            accent-color: var(--secondary);
        }

        .role-option label {
            margin: 0;
            font-weight: 500;
            cursor: pointer;
        }

        .form-errors {
            color: #c53030;
            font-size: 0.875rem;
            margin-top: 0.5rem;
            padding: 0.5rem;
            background-color: #fee;
            border-radius: 6px;
            border-left: 3px solid #c53030;
        }

        .form-actions {
            display: flex;
            gap: 1rem;
            justify-content: flex-end;
            margin-top: 2.5rem;
            padding-top: 1.5rem;
            border-top: 2px solid var(--accent);
        }

        .btn {
            padding: 0.875rem 2rem;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            font-weight: 600;
            text-decoration: none;
            display: inline-block;
            transition: all 0.3s ease;
            font-size: 0.95rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--secondary), #c97642);
            color: white;
            box-shadow: 0 4px 10px rgba(223, 145, 82, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(223, 145, 82, 0.4);
        }

        .btn-secondary {
            background: var(--accent);
            color: var(--dark);
            border: 2px solid var(--primary);
        }

        .btn-secondary:hover {
            background: var(--primary);
            transform: translateY(-2px);
        }
    </style>
{% endblock %}

{% block body %}
    <div class="hero-section">
        <h1>Add New User</h1>
    </div>

    <div class="form-container">
        {{ form_start(form) }}

            <div class="form-group">
                {{ form_label(form.username) }}
                {{ form_widget(form.username) }}
                {{ form_errors(form.username) }}
            </div>

            <div class="form-group">
                {{ form_label(form.email) }}
                {{ form_widget(form.email) }}
                {{ form_errors(form.email) }}
            </div>

            <div class="form-group">
                {{ form_label(form.fullName) }}
                {{ form_widget(form.fullName) }}
                {{ form_errors(form.fullName) }}
            </div>

            <div class="form-group">
                {{ form_label(form.plainPassword) }}
                {{ form_widget(form.plainPassword) }}
                {{ form_errors(form.plainPassword) }}
                {% if form.plainPassword.vars.help %}
                    <small class="form-help">{{ form.plainPassword.vars.help }}</small>
                {% endif %}
            </div>

            <div class="form-group">
                {{ form_label(form.roles) }}
                <div class="role-checkboxes">
                    {{ form_widget(form.roles) }}
                </div>
                {{ form_errors(form.roles) }}
            </div>

            <div class="form-actions">
                <a href="{{ path('admin_user_index') }}" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">Create User</button>
            </div>

        {{ form_end(form) }}
    </div>
{% endblock %}
