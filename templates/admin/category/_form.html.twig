{% extends 'admin/base.html.twig' %}

{% block title %}{{ category is defined and category.id ? 'Edit' : 'New' }} Category{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --primary: #e5a3a3;
            --secondary: #df9152;
            --accent: #ecc9c9;
            --dark: #5c3a3a;
            --light: #fdf6f6;
        }

        .form-page {
            background-color: var(--light);
            min-height: 100vh;
            padding: 2rem;
        }

        .form-container {
            max-width: 600px;
            margin: 0 auto;
            background: white;
            padding: 2.5rem;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(92, 58, 58, 0.12);
            border-top: 4px solid var(--primary);
        }

        .form-container h2 {
            margin-bottom: 2rem;
            color: var(--dark);
            font-size: 1.875rem;
            font-weight: 600;
            padding-bottom: 1rem;
            border-bottom: 2px solid var(--accent);
        }

        .form-group {
            margin-bottom: 1.75rem;
        }

        label {
            display: block;
            font-weight: 600;
            margin-bottom: 0.625rem;
            color: var(--dark);
            font-size: 0.95rem;
            letter-spacing: 0.3px;
        }

        input[type="text"], 
        select {
            width: 100%;
            padding: 0.875rem 1rem;
            border: 2px solid var(--accent);
            border-radius: 10px;
            font-size: 1rem;
            color: var(--dark);
            background-color: var(--light);
            transition: all 0.3s ease;
            box-sizing: border-box;
        }

        input[type="text"]:focus, 
        select:focus {
            outline: none;
            border-color: var(--primary);
            background-color: white;
            box-shadow: 0 0 0 3px rgba(229, 163, 163, 0.15);
        }

        select[multiple] {
            min-height: 150px;
            padding: 0.5rem;
        }

        select[multiple] option {
            padding: 0.5rem;
            border-radius: 6px;
            margin-bottom: 0.25rem;
        }

        select[multiple] option:hover {
            background-color: var(--accent);
        }

        .form-errors {
            color: #c53030;
            font-size: 0.875rem;
            margin-top: 0.5rem;
            padding: 0.5rem;
            background-color: #fee;
            border-radius: 6px;
            border-left: 3px solid #c53030;
        }

        .form-actions {
            display: flex;
            gap: 1rem;
            justify-content: flex-end;
            margin-top: 2.5rem;
            padding-top: 1.5rem;
            border-top: 2px solid var(--accent);
        }

        .btn {
            padding: 0.875rem 2rem;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            font-weight: 600;
            text-decoration: none;
            display: inline-block;
            transition: all 0.3s ease;
            font-size: 0.95rem;
            letter-spacing: 0.3px;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--secondary), var(--primary));
            color: white;
            box-shadow: 0 4px 10px rgba(223, 145, 82, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(223, 145, 82, 0.4);
            background: linear-gradient(135deg, var(--primary), var(--secondary));
        }

        .btn-secondary {
            background: var(--accent);
            color: var(--dark);
            border: 2px solid var(--primary);
        }

        .btn-secondary:hover {
            background: var(--primary);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(229, 163, 163, 0.3);
        }

        /* Form help text styling */
        .form-help {
            font-size: 0.875rem;
            color: #8b6b6b;
            margin-top: 0.375rem;
            font-style: italic;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="form-page">
        <div class="form-container">
            <h2>{{ category is defined and category.id ? 'Edit' : 'New' }} Category</h2>

            {{ form_start(form) }}
                <div class="form-group">
                    {{ form_label(form.name) }}
                    {{ form_widget(form.name) }}
                    {{ form_errors(form.name) }}
                </div>

                {# Optional: Assign products to category #}
                {% if form.products is defined %}
                    <div class="form-group">
                        {{ form_label(form.products, 'Products') }}
                        {{ form_widget(form.products, {'attr': {'multiple': 'multiple'}}) }}
                        {{ form_errors(form.products) }}
                        <small class="form-help">Hold Ctrl (Cmd on Mac) to select multiple products</small>
                    </div>
                {% endif %}

                <div class="form-actions">
                    <a href="{{ path('admin_category_index') }}" class="btn btn-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}