{% extends 'admin/base.html.twig' %}

{% block title %}Order Status & Tracking{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.dataTables.min.css">
    <style>
        :root {
            --primary: #ecc9c9;
            --secondary: #df9152;
            --accent: #e5a3a3;
            --dark: #2c2c2c;
            --light: #f8f9fa;
        }

        /* Layout uses global admin.css (same as Products tab) */

        table.dataTable {
            width: 100%;
            border-collapse: collapse;
        }

        table.dataTable thead {
            background: linear-gradient(135deg, var(--primary), var(--accent));
        }

        table.dataTable thead th {
            padding: 1.2rem 1.5rem;
            text-align: left;
            font-weight: 600;
            color: var(--dark);
            border-bottom: none;
        }

        table.dataTable tbody tr {
            border-bottom: 1px solid #f0f0f0;
            transition: background 0.2s;
        }

        table.dataTable tbody tr:hover {
            background: var(--light);
        }

        table.dataTable tbody td {
            padding: 1.2rem 1.5rem;
            color: #666;
        }

        .badge {
            padding: 0.35rem 0.75rem;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
            display: inline-block;
            margin: 0.2rem;
        }

        .badge-info { background: var(--accent); color: white; }
        .badge-warning { background: #f59e0b; color: white; }
        .badge-primary { background: var(--secondary); color: white; }
        .badge-secondary { background: #6b7280; color: white; }
        .badge-success { background: #10b981; color: white; }

        .action-buttons {
            display: flex;
            gap: 0.5rem;
        }

        .btn-action {
            padding: 0.5rem;
            border-radius: 8px;
            background: var(--primary);
            color: var(--dark);
            text-decoration: none;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-action:hover {
            background: var(--accent);
            transform: translateY(-1px);
        }

        .btn-action svg {
            width: 18px;
            height: 18px;
        }

        .dataTables_wrapper .dataTables_length,
        .dataTables_wrapper .dataTables_filter,
        .dataTables_wrapper .dataTables_info,
        .dataTables_wrapper .dataTables_paginate {
            padding: 1rem 1.5rem;
        }

        .dataTables_wrapper .dataTables_filter input {
            border: 2px solid var(--primary);
            border-radius: 8px;
            padding: 0.5rem 1rem;
        }

        .dataTables_wrapper .dataTables_length select {
            border: 2px solid var(--primary);
            border-radius: 8px;
            padding: 0.5rem;
        }
    </style>
{% endblock %}

{% block body %}
<div class="header">
    <h2>Order Status & Tracking</h2>
    <a href="{{ path('admin_order_place') }}" class="btn btn-primary">
        <svg fill="currentColor" viewBox="0 0 20 20" style="width: 16px; height: 16px; margin-right: 4px;">
            <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"></path>
        </svg>
        Place Order
    </a>
</div>

<div class="orders-table table-section">
    <table id="ordersTable" class="display responsive nowrap" style="width:100%">
        <thead>
            <tr>
                <th>Transaction ID</th>
                <th>Customer</th>
                <th>Items</th>
                <th>Total Amount</th>
                <th>Status</th>
                <th>Order Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for order in orders %}
            <tr>
                <td><strong>{{ order.transactionId }}</strong></td>
                <td>
                    <strong>{{ order.customerName }}</strong><br>
                    <small>{{ order.customerEmail }}</small>
                </td>
                <td>{{ order.itemsDescription|length > 50 ? order.itemsDescription|slice(0, 50) ~ '...' : order.itemsDescription }}</td>
                <td><strong style="color: var(--secondary); font-size: 16px;">${{ order.totalAmount }}</strong></td>
                <td>
                    <span class="badge {{ order.statusBadgeClass }}">
                        {{ order.statusLabel }}
                    </span>
                    {% if order.status == 'shipping' and order.trackingNumber %}
                        <br><small title="Tracking: {{ order.trackingNumber }}">Tracking available</small>
                    {% endif %}
                </td>
                <td>{{ order.orderDate|date('M d, Y') }}</td>
                <td>
                    <a href="{{ path('admin_order_show', {id: order.id}) }}" class="btn-action" title="View & Process">
                        <svg fill="currentColor" viewBox="0 0 20 20"><path d="M10 12a2 2 0 100-4 2 2 0 000 4z"></path><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"></path></svg>
                    </a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
    <script>
    (function () {
        let liveTimer = null;
        const LIVE_CHECK_MS = 1000;
        let knownLatestOrderId = Number('{{ latestOrderId ?? 0 }}') || 0;
        const websocketUrl = '{{ websocketUrl|default("") }}';

        function initOrderStatusAutoRefresh() {
            const tableEl = $('#ordersTable');
            if (!tableEl.length) {
                return;
            }

            if ($.fn.DataTable.isDataTable('#ordersTable')) {
                $('#ordersTable').DataTable().destroy();
            }

            const table = tableEl.DataTable({
            responsive: true,
            order: [[5, 'desc']],
            pageLength: 25,
            language: {
                search: "Search orders:",
                lengthMenu: "Show _MENU_ orders per page",
                info: "Showing _START_ to _END_ of _TOTAL_ orders",
                emptyTable: "No orders found",
                zeroRecords: "No matching orders found"
            }
        });

            async function pollLiveUpdates() {
                try {
                    const res = await fetch('{{ path("admin_realtime_updates") }}', {
                        credentials: 'include',
                        headers: { Accept: 'application/json' },
                    });
                    if (!res.ok) {
                        return;
                    }
                    const payload = await res.json();
                    const serverLatestOrderId = Number(payload?.data?.latestOrderId || 0);

                    if (serverLatestOrderId > knownLatestOrderId) {
                        const currentSearch = table.search();
                        const currentPage = table.page();
                        const state = { search: currentSearch, page: currentPage };
                        sessionStorage.setItem('adminOrdersTableState', JSON.stringify(state));
                        window.location.reload();
                        return;
                    }
                    knownLatestOrderId = Math.max(knownLatestOrderId, serverLatestOrderId);
                } catch (e) {
                    // silent fallback: user can still refresh manually
                }
            }

            const saved = sessionStorage.getItem('adminOrdersTableState');
            if (saved) {
            try {
                const state = JSON.parse(saved);
                if (typeof state.search === 'string') {
                    table.search(state.search).draw();
                }
                if (typeof state.page === 'number') {
                    table.page(state.page).draw('page');
                }
            } catch (e) {
                // ignore parse failures
            } finally {
                sessionStorage.removeItem('adminOrdersTableState');
            }
        }

            if (liveTimer) {
                clearInterval(liveTimer);
            }
            liveTimer = setInterval(() => {
                if (!document.hidden) {
                    pollLiveUpdates();
                }
            }, LIVE_CHECK_MS);

            if (websocketUrl) {
                try {
                    const ws = new WebSocket(websocketUrl);
                    ws.onmessage = function (message) {
                        try {
                            const event = JSON.parse(message.data || '{}');
                            if (event?.type === 'order.created' || event?.type === 'order.status.updated') {
                                const currentSearch = table.search();
                                const currentPage = table.page();
                                sessionStorage.setItem(
                                    'adminOrdersTableState',
                                    JSON.stringify({ search: currentSearch, page: currentPage }),
                                );
                                window.location.reload();
                            }
                        } catch (e) {
                            // ignore malformed websocket payloads
                        }
                    };
                } catch (e) {
                    // fallback polling remains active
                }
            }
        }

        document.addEventListener('DOMContentLoaded', initOrderStatusAutoRefresh);
        document.addEventListener('turbo:load', initOrderStatusAutoRefresh);
    })();
    </script>
{% endblock %}
