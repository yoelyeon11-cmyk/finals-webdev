{# templates/admin/dashboard/index.html.twig #}
{% extends 'admin/base.html.twig' %}

{% block title %}Dashboard - Cloudrobe Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.dataTables.min.css">
    <style>
        /* Custom DataTables styling to match your theme */
        .dataTables_wrapper .dataTables_length,
        .dataTables_wrapper .dataTables_filter,
        .dataTables_wrapper .dataTables_info,
        .dataTables_wrapper .dataTables_paginate {
            color: var(--text-secondary);
            padding: 12px 0;
        }
        
        .dataTables_wrapper .dataTables_filter input {
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 8px 12px;
            background: var(--surface);
            color: var(--text);
            margin-left: 8px;
        }
        
        .dataTables_wrapper .dataTables_length select {
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 6px 12px;
            background: var(--surface);
            color: var(--text);
            margin: 0 8px;
        }
        
        .dataTables_wrapper .dataTables_paginate .paginate_button {
            border: 1px solid var(--border);
            background: var(--surface);
            color: var(--text) !important;
            border-radius: 6px;
            padding: 6px 12px;
            margin: 0 2px;
        }
        
        .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
            background: var(--accent);
            border-color: var(--accent);
            color: white !important;
        }
        
        .dataTables_wrapper .dataTables_paginate .paginate_button.current {
            background: var(--primary);
            border-color: var(--primary);
            color: white !important;
        }
        
        table.dataTable thead th {
            border-bottom: 2px solid var(--border);
        }
        
        table.dataTable tbody tr {
            border-bottom: 1px solid var(--border);
        }
        
        table.dataTable tbody tr:hover {
            background: var(--hover);
        }
        
        /* Remove the default search box since DataTables has its own */
        .table-header .search-box {
            display: none;
        }
        
        .dataTables_wrapper {
            padding: 0;
        }
    </style>
{% endblock %}

{% block body %}
<div class="header">
    <h2>Dashboard</h2>
    <div class="header-actions">
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <h3>Total Products</h3>
        <div class="number" id="statTotalProducts">{{ stats.totalProducts }}</div>
        <div class="change"></div>
    </div>
    <div class="stat-card">
        <h3>Categories</h3>
        <div class="number" id="statTotalCategories">{{ stats.totalCategories }}</div>
        <div class="change"></div>
    </div>
    <div class="stat-card">
        <h3>Low Stock Items</h3>
        <div class="number" id="statLowStockCount">{{ stats.lowStockCount }}</div>
        <div class="change" style="color: #dc3545;"></div>
    </div>
    <div class="stat-card">
        <h3>Total Value</h3>
        <div class="number" id="statTotalValue">₱{{ stats.totalValue|number_format(0, '.', ',') }}</div>
        <div class="change"></div>
    </div>
</div>

<div class="table-section">
    <div class="table-header">
        <h3>Recent Products</h3>
    </div>
    <table id="productsTable" class="display responsive nowrap" style="width:100%">
        <thead>
            <tr>
                <th>Product Name</th>
                <th>Category</th>
                <th>Stock</th>
                <th>Price</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            {% for product in recentProducts %}
            <tr data-product-id="{{ product.id }}">
                <td>{{ product.name }}</td>
                <td>{{ product.category ? product.category.name : 'No Category' }}</td>    
                <td data-order="{{ product.stock }}">{{ product.stock }}</td>
                <td data-order="{{ product.price }}">₱{{ product.price|number_format(2) }}</td>
                <td data-order="{% if product.stock > 20 %}3{% elseif product.stock > 0 %}2{% else %}1{% endif %}">
                    {% if product.stock > 20 %}
                        <span class="badge badge-success">In Stock</span>
                    {% elseif product.stock > 0 %}
                        <span class="badge badge-warning">Low Stock</span>
                    {% else %}
                        <span class="badge badge-danger">Out of Stock</span>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
    <script>
    (function () {
        let liveTimer = null;
        let dashboardWs = null;
        let dashboardTable = null;
        const LIVE_CHECK_MS = 1000;
        let knownProductsFingerprint = '{{ productsFingerprint|default("") }}';
        let knownLatestProductId = Number('{{ latestProductId ?? 0 }}') || 0;
        const websocketUrl = '{{ websocketUrl|default("") }}';
        const statsJsonUrl = '{{ path("admin_dashboard_stats_json") }}';
        const realtimeUpdatesUrl = '{{ path("admin_realtime_updates") }}';

        function escapeHtml(value) {
            return String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;');
        }

        function stockBadge(stock) {
            if (stock > 20) {
                return '<span class="badge badge-success">In Stock</span>';
            }
            if (stock > 0) {
                return '<span class="badge badge-warning">Low Stock</span>';
            }
            return '<span class="badge badge-danger">Out of Stock</span>';
        }

        function stockOrder(stock) {
            if (stock > 20) {
                return 3;
            }
            if (stock > 0) {
                return 2;
            }
            return 1;
        }

        function applyDashboardData(data) {
            const stats = data?.stats || {};
            const totalProductsEl = document.getElementById('statTotalProducts');
            const totalCategoriesEl = document.getElementById('statTotalCategories');
            const lowStockEl = document.getElementById('statLowStockCount');
            const totalValueEl = document.getElementById('statTotalValue');

            if (totalProductsEl) {
                totalProductsEl.textContent = String(stats.totalProducts ?? 0);
            }
            if (totalCategoriesEl) {
                totalCategoriesEl.textContent = String(stats.totalCategories ?? 0);
            }
            if (lowStockEl) {
                lowStockEl.textContent = String(stats.lowStockCount ?? 0);
            }
            if (totalValueEl) {
                const value = Number(stats.totalValue || 0);
                totalValueEl.textContent = '₱' + value.toLocaleString('en-PH', { maximumFractionDigits: 0 });
            }

            if (!dashboardTable) {
                return;
            }

            dashboardTable.clear();
            (data.recentProducts || []).forEach(function (product) {
                const stock = Number(product.stock || 0);
                const price = Number(product.price || 0);
                dashboardTable.row.add([
                    escapeHtml(product.name),
                    escapeHtml(product.categoryName),
                    String(stock),
                    '₱' + price.toLocaleString('en-PH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }),
                    stockBadge(stock),
                ]);
            });
            dashboardTable.draw(false);
        }

        async function refreshDashboardFromServer() {
            try {
                const res = await fetch(statsJsonUrl, {
                    credentials: 'include',
                    headers: { Accept: 'application/json' },
                });
                if (!res.ok) {
                    return;
                }
                const payload = await res.json();
                if (!payload?.success || !payload?.data) {
                    return;
                }
                knownProductsFingerprint = payload.data.productsFingerprint || knownProductsFingerprint;
                knownLatestProductId = Math.max(knownLatestProductId, Number(payload.data.latestProductId || 0));
                applyDashboardData(payload.data);
            } catch (e) {
                // silent fallback
            }
        }

        async function pollLiveUpdates() {
            try {
                const res = await fetch(realtimeUpdatesUrl, {
                    credentials: 'include',
                    headers: { Accept: 'application/json' },
                });
                if (!res.ok) {
                    return;
                }
                const payload = await res.json();
                const data = payload?.data || {};
                const serverFingerprint = String(data.productsFingerprint || '');
                const serverLatestProductId = Number(data.latestProductId || 0);

                if (
                    (serverFingerprint && serverFingerprint !== knownProductsFingerprint)
                    || serverLatestProductId > knownLatestProductId
                ) {
                    await refreshDashboardFromServer();
                }
            } catch (e) {
                // silent fallback
            }
        }

            async function handleRealtimeEvent(event) {
                const type = event?.type || '';
                if (
                    type === 'product.created'
                    || type === 'product.updated'
                    || type === 'product.deleted'
                    || type === 'inventory.updated'
                    || type === 'category.created'
                    || type === 'category.updated'
                    || type === 'category.deleted'
                    || type === 'order.created'
                    || type === 'custom_request.created'
                    || type === 'verification.updated'
                ) {
                    await refreshDashboardFromServer();
                }
            }

        function teardownLiveDashboard() {
            if (liveTimer) {
                clearInterval(liveTimer);
                liveTimer = null;
            }
            if (dashboardWs) {
                dashboardWs.close();
                dashboardWs = null;
            }
        }

        function initDashboardLive() {
            if (typeof window.$ === 'undefined' || !document.getElementById('productsTable')) {
                return;
            }

            teardownLiveDashboard();

            if ($.fn.DataTable.isDataTable('#productsTable')) {
                $('#productsTable').DataTable().destroy();
            }

            dashboardTable = $('#productsTable').DataTable({
                responsive: true,
                pageLength: 25,
                order: [[0, 'asc']],
                language: {
                    search: "Search products:",
                    lengthMenu: "Show _MENU_ products per page",
                    info: "Showing _START_ to _END_ of _TOTAL_ products",
                    infoEmpty: "No products available",
                    emptyTable: "No products found in the database",
                    zeroRecords: "No matching products found",
                },
            });

            pollLiveUpdates();

            liveTimer = setInterval(function () {
                if (!document.hidden) {
                    pollLiveUpdates();
                }
            }, LIVE_CHECK_MS);

            if (websocketUrl) {
                try {
                    dashboardWs = new WebSocket(websocketUrl);
                    dashboardWs.onmessage = function (message) {
                        try {
                            const event = JSON.parse(message.data || '{}');
                            handleRealtimeEvent(event);
                        } catch (e) {
                            // ignore malformed payloads
                        }
                    };
                } catch (e) {
                    // polling fallback remains active
                }
            }
        }

        document.addEventListener('DOMContentLoaded', initDashboardLive);
        document.addEventListener('turbo:load', initDashboardLive);
        document.addEventListener('turbo:before-cache', teardownLiveDashboard);
    })();
    </script>
{% endblock %}