{% extends 'base.html.twig' %}

{% block title %}CLOUDROBE - your cosplay in full color{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'partials/_public_theme_styles.html.twig' %}
    <style>
        .landing-textured {
            background-color: var(--light-bg);
            background-image:
                linear-gradient(130deg, rgba(236, 201, 201, 0.66) 0%, rgba(229, 163, 163, 0.52) 45%, rgba(223, 145, 82, 0.4) 100%),
                url('/images/collections/landing-clouds.png');
            background-repeat: no-repeat, repeat-y;
            background-size: cover, cover;
            background-position: center top, center top;
            background-attachment: fixed, fixed;
        }

        @media (max-width: 768px) {
            .landing-textured {
                background-attachment: scroll, scroll;
                background-size: cover, auto 900px;
            }
        }

        .landing-section {
            padding: clamp(3rem, 8vw, 5rem) clamp(1rem, 4vw, 2rem);
        }

        .section-title {
            text-align: center;
            font-size: clamp(1.75rem, 5vw, 2.75rem);
            margin: 0 0 0.75rem;
            background: linear-gradient(45deg, var(--accent-orange), var(--secondary-pink));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .section-lead {
            text-align: center;
            max-width: 42rem;
            margin: 0 auto 2.5rem;
            line-height: 1.65;
            font-size: clamp(0.95rem, 2.5vw, 1.1rem);
            color: var(--dark-text);
            opacity: 0.92;
        }

        /* Hero */
        .hero-section {
            min-height: calc(100vh - var(--site-header-offset));
            min-height: calc(100dvh - var(--site-header-offset));
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: clamp(2rem, 6vw, 4rem) clamp(1rem, 4vw, 2rem);
        }

        .hero-content {
            max-width: 800px;
            padding: 1rem;
        }

        .hero-title {
            font-size: clamp(2.25rem, 8vw, 4.5rem);
            font-weight: 900;
            margin: 0 0 1rem;
            background: linear-gradient(45deg, var(--white), var(--accent-orange));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 2px;
        }

        .hero-subtitle {
            font-size: clamp(1.15rem, 4vw, 2rem);
            color: var(--white);
            margin: 0 0 2rem;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
            line-height: 1.4;
        }

        .cta-buttons {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .cta-button {
            background: var(--accent-orange);
            color: var(--white);
            padding: 0.9rem 2rem;
            border: none;
            border-radius: 50px;
            font-weight: 700;
            font-size: clamp(0.95rem, 2.5vw, 1.05rem);
            text-decoration: none;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            min-width: min(100%, 180px);
        }

        .cta-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 28px rgba(223, 145, 82, 0.4);
            color: var(--white);
        }

        .cta-button-secondary {
            background: transparent;
            border: 2px solid var(--white);
            color: var(--white);
        }

        .cta-button-secondary:hover {
            background: var(--white);
            color: var(--accent-orange);
        }

        /* Features */
        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
            gap: clamp(1.25rem, 3vw, 2rem);
            max-width: 1200px;
            margin: 0 auto;
        }

        .feature-card {
            background: rgba(255, 255, 255, 0.88);
            padding: clamp(1.25rem, 3vw, 2rem);
            border-radius: 20px;
            border: 1px solid var(--border-soft);
            text-align: center;
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }

        .feature-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 16px 36px rgba(236, 201, 201, 0.35);
        }

        .feature-icon {
            font-size: clamp(2rem, 6vw, 3rem);
            margin-bottom: 0.75rem;
            color: var(--accent-orange);
            display: block;
        }

        .feature-card h3 {
            font-size: clamp(1.1rem, 3vw, 1.4rem);
            margin: 0 0 0.75rem;
            color: var(--accent-orange);
        }

        .feature-card p {
            margin: 0;
            line-height: 1.6;
            font-size: clamp(0.9rem, 2.4vw, 1rem);
            color: #6b4747;
        }

        /* Steps */
        .steps-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(min(100%, 240px), 1fr));
            gap: clamp(1.25rem, 3vw, 2rem);
            max-width: 1100px;
            margin: 0 auto;
        }

        .step-card {
            background: rgba(255, 255, 255, 0.92);
            border-radius: 18px;
            padding: 1.75rem 1.5rem;
            border: 1px solid var(--border-soft);
            box-shadow: 0 8px 28px rgba(92, 58, 58, 0.08);
            text-align: center;
        }

        .step-num {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 2.75rem;
            height: 2.75rem;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--secondary-pink), var(--accent-orange));
            color: var(--white);
            font-weight: 800;
            margin-bottom: 1rem;
        }

        .step-card h3 {
            font-size: 1.15rem;
            margin: 0 0 0.5rem;
            color: var(--secondary-pink);
        }

        .step-card p {
            margin: 0;
            line-height: 1.6;
            font-size: 0.95rem;
            color: #6b4747;
        }

        /* Collections */
        .collections-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
            gap: clamp(1.25rem, 3vw, 2rem);
            max-width: 1200px;
            margin: 0 auto;
        }

        .collection-card {
            background: rgba(255, 255, 255, 0.9);
            border-radius: 15px;
            border: 1px solid var(--border-soft);
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .collection-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(92, 58, 58, 0.15);
        }

        .collection-image {
            height: clamp(180px, 35vw, 220px);
            overflow: hidden;
            background: rgba(229, 163, 163, 0.4);
        }

        .collection-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .collection-info {
            padding: 1.25rem;
        }

        .collection-info h3 {
            margin: 0 0 0.35rem;
            color: var(--secondary-pink);
            font-size: clamp(1.05rem, 3vw, 1.25rem);
        }

        .collection-price {
            margin: 0;
            color: var(--accent-orange);
            font-weight: 600;
        }

        /* Stats */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(min(100%, 140px), 1fr));
            gap: clamp(1rem, 3vw, 2rem);
            max-width: 1000px;
            margin: 0 auto;
            text-align: center;
        }

        .stat-item {
            background: rgba(255, 255, 255, 0.85);
            border-radius: 16px;
            padding: 1.5rem 1rem;
            border: 1px solid var(--border-soft);
        }

        .stat-item h3 {
            font-size: clamp(1.75rem, 6vw, 2.5rem);
            color: var(--accent-orange);
            margin: 0 0 0.35rem;
        }

        .stat-item p {
            margin: 0;
            font-size: clamp(0.9rem, 2.4vw, 1.05rem);
        }

        /* Testimonials */
        .testimonials-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
            gap: 1.25rem;
            max-width: 1100px;
            margin: 0 auto;
        }

        .testimonial-card {
            background: rgba(255, 255, 255, 0.9);
            border-radius: 16px;
            padding: 1.5rem;
            border: 1px solid var(--border-soft);
            margin: 0;
        }

        .testimonial-card blockquote {
            margin: 0 0 1rem;
            font-size: clamp(0.92rem, 2.4vw, 1rem);
            line-height: 1.65;
            font-style: italic;
            color: #6b4747;
        }

        .testimonial-card figcaption {
            font-size: 0.88rem;
            font-weight: 700;
            color: var(--accent-orange);
        }

        /* Final CTA */
        .cta-final-section {
            text-align: center;
            padding-bottom: clamp(4rem, 10vw, 6rem);
        }

        .cta-final-inner {
            max-width: 36rem;
            margin: 0 auto;
            background: rgba(255, 255, 255, 0.9);
            border-radius: 20px;
            padding: clamp(1.5rem, 4vw, 2.5rem);
            border: 1px solid var(--border-soft);
        }

        .cta-final-inner h2 {
            font-size: clamp(1.4rem, 4vw, 2rem);
            margin: 0 0 0.75rem;
            color: var(--dark-text);
        }

        .cta-final-inner p {
            margin: 0 0 1.25rem;
            line-height: 1.65;
            font-size: clamp(0.95rem, 2.5vw, 1.05rem);
        }

        .cta-final-links {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            justify-content: center;
        }

        .cta-button-outline {
            background: transparent;
            border: 2px solid var(--accent-orange);
            color: var(--accent-orange);
        }

        .cta-button-outline:hover {
            background: var(--accent-orange);
            color: var(--white);
        }

        /* Search results */
        .search-results-section {
            padding-top: 2rem;
        }

        .search-empty {
            text-align: center;
            max-width: 28rem;
            margin: 0 auto;
            line-height: 1.6;
        }

        @media (max-width: 768px) {
            .cta-buttons,
            .cta-final-links {
                flex-direction: column;
                align-items: stretch;
            }

            .cta-button {
                text-align: center;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="public-site landing-textured">
    {% include 'partials/public_header.html.twig' %}

    {% if query is empty %}
        <section class="hero-section" aria-label="Introduction">
            <div class="hero-content">
                <h1 class="hero-title">CLOUDROBE</h1>
                <p class="hero-subtitle">Bring your characters to life in full color.</p>
                <div class="cta-buttons">
                    <a href="#collections" class="cta-button">Explore collections</a>
                    <a href="{{ path('app_contact') }}" class="cta-button cta-button-secondary">Get in touch</a>
                </div>
            </div>
        </section>

        <section class="landing-section features-section" id="features" aria-labelledby="features-heading">
            <h2 id="features-heading" class="section-title">Why cosplayers choose Cloudrobe</h2>
            <p class="section-lead">Thoughtful materials, honest timelines, and builds made to survive the convention floor.</p>
            <div class="features-grid">
                <article class="feature-card">
                    <span class="feature-icon" aria-hidden="true">◆</span>
                    <h3>Screen-accurate color</h3>
                    <p>Curated fabrics and dyes so your costume reads true on camera and in hall lighting—not just in the bag.</p>
                </article>
                <article class="feature-card">
                    <span class="feature-icon" aria-hidden="true">◆</span>
                    <h3>Clear sizing &amp; care</h3>
                    <p>Measurements and care notes help your outfit last through cons, shoots, and last-minute fixes.</p>
                </article>
                <article class="feature-card">
                    <span class="feature-icon" aria-hidden="true">◆</span>
                    <h3>Human support</h3>
                    <p>Questions about fit or a rush deadline? Our team answers in plain language—no ticket black holes.</p>
                </article>
            </div>
        </section>

        <section class="landing-section how-section" id="how-it-works" aria-labelledby="how-heading">
            <h2 id="how-heading" class="section-title">How it works</h2>
            <p class="section-lead">From first sketch to final stitch—we keep the path simple so you can focus on the character.</p>
            <div class="steps-grid">
                <article class="step-card">
                    <div class="step-num" aria-hidden="true">1</div>
                    <h3>Browse or brief us</h3>
                    <p>Shop ready-to-wear lines or share your custom concept, budget, and deadline.</p>
                </article>
                <article class="step-card">
                    <div class="step-num" aria-hidden="true">2</div>
                    <h3>Confirm materials &amp; fit</h3>
                    <p>We lock colorways, fabrics, and sizing so there are no surprises at unboxing.</p>
                </article>
                <article class="step-card">
                    <div class="step-num" aria-hidden="true">3</div>
                    <h3>Ships to your door</h3>
                    <p>Carefully packed and tracked—ready for your next con, shoot, or group cosplay.</p>
                </article>
            </div>
        </section>

        <section class="landing-section collections-section" id="collections" aria-labelledby="collections-heading">
            <h2 id="collections-heading" class="section-title">Featured collections</h2>
            <p class="section-lead">Popular lines our customers reach for first—each built with the same color discipline as custom work.</p>
            <div class="collections-grid">
                <article class="collection-card">
                    <div class="collection-image">
                        <img src="{{ asset('images/collections/HatsuneMiku.jpg') }}" alt="Vocaloid collection preview" loading="lazy">
                    </div>
                    <div class="collection-info">
                        <h3>Vocaloid set</h3>
                        <p class="collection-price">Starting from ₱1,000</p>
                    </div>
                </article>
                <article class="collection-card">
                    <div class="collection-image">
                        <img src="{{ asset('images/collections/mizu5cosplay.webp') }}" alt="Mizuki Akiyama collection preview" loading="lazy">
                    </div>
                    <div class="collection-info">
                        <h3>Mizuki Akiyama 5 set</h3>
                        <p class="collection-price">Starting from ₱1,000</p>
                    </div>
                </article>
                <article class="collection-card">
                    <div class="collection-image">
                        <img src="{{ asset('images/collections/columbinacosplay.webp') }}" alt="Nod Krai collection preview" loading="lazy">
                    </div>
                    <div class="collection-info">
                        <h3>Nod Krai characters set</h3>
                        <p class="collection-price">Starting from ₱1,000</p>
                    </div>
                </article>
            </div>
        </section>

        <section class="landing-section stats-section" aria-labelledby="stats-heading">
            <h2 id="stats-heading" class="section-title">By the numbers</h2>
            <div class="stats-grid">
                <div class="stat-item">
                    <h3>10,000+</h3>
                    <p>Happy customers</p>
                </div>
                <div class="stat-item">
                    <h3>500+</h3>
                    <p>Costume styles</p>
                </div>
                <div class="stat-item">
                    <h3>98%</h3>
                    <p>Satisfaction rate</p>
                </div>
                <div class="stat-item">
                    <h3>24/7</h3>
                    <p>Support window</p>
                </div>
            </div>
        </section>

        <section class="landing-section testimonials-section" id="testimonials" aria-labelledby="testimonials-heading">
            <h2 id="testimonials-heading" class="section-title">From the community</h2>
            <p class="section-lead">Real feedback from cosplayers who needed color accuracy under pressure.</p>
            <div class="testimonials-grid">
                <figure class="testimonial-card">
                    <blockquote>“The dye match was dead-on under con hall lights—photos finally looked like the reference.”</blockquote>
                    <figcaption>— Mika R., Vocaloid build</figcaption>
                </figure>
                <figure class="testimonial-card">
                    <blockquote>“Sizing notes were clear and the team replied same day when I asked about a rush deadline.”</blockquote>
                    <figcaption>— Jules T., custom commission</figcaption>
                </figure>
                <figure class="testimonial-card">
                    <blockquote>“Packaging kept everything crisp after shipping. No crushed trims or faded panels.”</blockquote>
                    <figcaption>— Alex P., Nod Krai set</figcaption>
                </figure>
            </div>
        </section>

        <section class="landing-section cta-final-section" id="custom" aria-labelledby="custom-heading">
            <div class="cta-final-inner">
                <h2 id="custom-heading">Need something one of a kind?</h2>
                <p>Commission a custom build with the same color discipline as our ready-made lines. Share references and we will outline timeline and options.</p>
                <div class="cta-final-links">
                    <a href="{{ path('app_contact') }}" class="cta-button">Request a custom quote</a>
                    <a href="{{ path('app_about') }}" class="cta-button cta-button-outline">Meet the team</a>
                </div>
            </div>
        </section>
    {% else %}
        <section class="landing-section search-results-section" id="search-results" aria-labelledby="search-heading">
            <h2 id="search-heading" class="section-title">Results for “{{ query }}”</h2>
            {% if products is empty %}
                <p class="search-empty">No products matched your search. Try another keyword or <a href="{{ path('app_home_page') }}">browse all collections</a>.</p>
            {% else %}
                <div class="collections-grid">
                    {% for product in products %}
                        <article class="collection-card">
                            <a href="{{ path('admin_product_show', { id: product.id }) }}" style="text-decoration: none; color: inherit;">
                                <div class="collection-image">
                                    <img src="/uploads/{{ product.image }}" alt="{{ product.name }}" loading="lazy">
                                </div>
                                <div class="collection-info">
                                    <h3>{{ product.name }}</h3>
                                    <p class="collection-price">₱{{ product.price }}</p>
                                </div>
                            </a>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </section>
    {% endif %}

    {% include 'partials/public_footer.html.twig' %}
    {% include 'partials/public_search_script.html.twig' %}
</div>
{% endblock %}
