# Copy to .env.local and fill in (this file is safe to commit; .env.local is gitignored)

###> symfony/mailer ###
MAILER_DSN=smtp://USER:KEY@smtp-relay.brevo.com:587
###< symfony/mailer ###

###> google/oauth ###
OAUTH_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
###< google/oauth ###

###> lexik/jwt-authentication-bundle ###
JWT_PASSPHRASE=generate-a-long-random-passphrase
###< lexik/jwt-authentication-bundle ###
